<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<fonts>
  <font name="default" comment="default font files (global fallbacks)">
    <file>IBMPlexSansJP-Regular.otf</file>
    <file functor="is_emoji_use_color">TwemojiSVG.ttf</file>
    <file functor="is_emoji_use_bw">NotoEmoji-Regular.ttf</file>
  </font>
  <font name="SansSerifBold" comment="Name of bold sans-serif font">
    <file>IBMPlexSansJP-Bold.otf</file>
  </font>
  <font name="SansSerif" comment="Name of sans-serif font">
    <file>IBMPlexSansJP-Regular.otf</file>
  </font>
  <font name="SansSerif" comment="Name of bold sans-serif font" font_style="BOLD">
    <file>IBMPlexSansJP-Bold.otf</file>
  </font>
  <font name="SansSerif" comment="Name of italic sans-serif font" font_style="ITALIC">
    <file>IBMPlexSansJP-Regular.otf</file>
  </font>
  <font name="SansSerif" comment="Name of bold italic sans-serif font" font_style="BOLD|ITALIC">
    <file>IBMPlexSansJP-Bold.otf</file>
  </font>
  <font name="Emoji" comment="Name of emoji font">
    <file>TwemojiSVG.ttf</file>
  </font>
  <font name="EmojiBW" comment="Name of emoji font">
    <file>NotoEmoji-Regular.ttf</file>
  </font>
  <font name="Monospace" comment="Name of monospace font">
    <file>DejaVuSansMono.ttf</file>
  </font>
  <font name="Scripting" comment="Name of an optional font used for the script editor">
    <file>SourceCodePro-Regular.ttf</file>
  </font>
  <font name="DejaVu" comment="Name of DejaVu font">
    <file>IBMPlexSansJP-Regular.otf</file>
  </font>
  <font name="DejaVu" comment="Name of DejaVu font (bold)" font_style="BOLD">
    <file>IBMPlexSansJP-Bold.otf</file>
  </font>
  <font name="Helvetica" comment="Name of Helvetica font">
    <file>IBMPlexSansJP-Regular.otf</file>
  </font>
  <font name="Helvetica" comment="Name of Helvetica font (bold)" font_style="BOLD">
    <file>IBMPlexSansJP-Bold.otf</file>
  </font>
  <font_size name="Huge" comment="Size of huge font" size="16.0" />
  <font_size name="Large" comment="Size of large font" size="10.6" />
  <font_size name="Medium" comment="Size of medium font" size="8.6" />
  <font_size name="Small" comment="Size of small font" size="7.6" />
  <font_size name="Monospace" comment="Size for monospaced font" size="8.0" />
  <font_size name="Scripting" comment="Size of script editor font" size="8.6" />
  <font_size name="Pie" comment="Size of pie menu font" size="7.3" />
</fonts>
