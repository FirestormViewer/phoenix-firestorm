<?xml version='1.0' encoding='utf-8'?>
<panel background_visible="true" follows="all" height="400" layout="topleft" left="0" name="edit_hair_panel" top_pad="10" width="333">

	 <panel border="false" follows="top|left|right" height="80" left="0" layout="topleft" name="avatar_hair_color_panel" top="0" width="333">
