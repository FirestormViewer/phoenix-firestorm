      <accordion_tab layout="topleft" min_height="150" name="hair_color_tab" fit_panel="false" title="Cor">
      
      <scrolling_panel_list layout="topleft" follows="all" left="0" name="hair_color_param_list" top="0" height="266" width="333" />
      </accordion_tab>
      </accordion>
      </panel>
      

      
