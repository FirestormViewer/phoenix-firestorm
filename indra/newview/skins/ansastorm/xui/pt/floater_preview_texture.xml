<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="preview_texture">
	<floater.string name="Title">
		Textura: [NAME]
	</floater.string>
	<floater.string name="Copy">
		Copiar para o inventário
	</floater.string>
	<floater.string name="DateTime">
		[weekday,datetime,slt], [day,datetime,slt]. [month,datetime,slt] [year,datetime,slt], [hour24,datetime,slt]:[min,datetime,slt]:[second,datetime,slt] [timezone,datetime,slt]
	</floater.string>
	<text name="desc txt">
		Descrição:
	</text>
	<text name="uploader_label">
		Enviado por:
	</text>
	<button label="Perfil" name="openprofile"/>
	<text name="upload_time_label">
		Data:
	</text>
	<text name="uuid_label">
		UUID:
	</text>
	<button label="Copiar" name="copyuuid"/>
	<panel name="dimensions_panel">
		<text name="dimensions">
			[WIDTH]px x [HEIGHT]px
		</text>
		<text name="aspect_ratio">
			Proporção de aspecto
		</text>
		<combo_box name="combo_aspect_ratio" tool_tip="Visualizar com proporção fixa">
			<combo_item name="Unconstrained">
				Irrestrito
			</combo_item>
			<combo_item name="1:1" tool_tip="Emblema de grupo ou descrição">
				1:1
			</combo_item>
			<combo_item name="4:3" tool_tip="Perfil [CURRENT_GRID]">
				4:3
			</combo_item>
			<combo_item name="10:7" tool_tip="Anúncios e resultados de busca, marcos">
				10:7
			</combo_item>
			<combo_item name="3:2" tool_tip="Sobre o terreno">
				3:2
			</combo_item>
			<combo_item name="16:10">
				16:10
			</combo_item>
			<combo_item name="16:9" tool_tip="Seleção de perfil">
				16:9
			</combo_item>
			<combo_item name="2:1">
				2:1
			</combo_item>
		</combo_box>
	</panel>
	<panel name="button_panel">
		<button label="OK" name="Keep"/>
		<button label="Descartar" name="Discard"/>
		<flyout_button label="Salvar..." name="save_tex_btn">
			<flyout_button.item label="Salvar como TGA" name="save_item_tga"/>
			<flyout_button.item label="Salvar como PNG" name="save_item_png"/>
		</flyout_button>
	</panel>
</floater>
