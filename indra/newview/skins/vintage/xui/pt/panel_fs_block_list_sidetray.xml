<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel name="block_list_panel">
	<string name="no_blocked" value="Nenhum residente ou objeto bloqueado."/>
	<string name="no_filtered_blocked" value="Nenhum residente ou objeto bloqueado corresponde à sua busca."/>
	<string name="loading_blocked" value="Carregando residentes e objetos bloqueados..."/>
	<string name="failed_blocked" value="A lista de bloqueados não está disponível no momento."/>
	<fs_scroll_list name="block_list">
		<fs_scroll_list.columns name="item_name" label="Nome"/>
		<fs_scroll_list.columns name="item_type" label="Tipo"/>
	</fs_scroll_list>
	<text name="block_limit">
		Entradas bloqueadas: [COUNT] ([LIMIT] máx.)
	</text>
	<layout_stack name="block_list_sidetray_main">
		<layout_panel name="back_button_container">
			<button tool_tip="Voltar para Pessoas" name="back"/>
		</layout_panel>
		<layout_panel name="block_list_blocklaypanels">
			<layout_stack name="block_list_blocklaystack">
				<layout_panel name="block_panels_btnsort">
					<menu_button label="Ordenar..." name="view_btn" tool_tip="Opções de ordenação"/>
				</layout_panel>
				<layout_panel name="block_panels_btnpersonobject">
					<menu_button label="Bloquear..." name="plus_btn" tool_tip="Escolher residente ou objeto para ignorar"/>
				</layout_panel>
				<layout_panel name="block_panels_btnunblock">
					<button label="Desbloquear" name="unblock_btn" tool_tip="Remover residente ou objeto da lista de ignorados"/>
				</layout_panel>
			</layout_stack>
		</layout_panel>
	</layout_stack>
</panel>
