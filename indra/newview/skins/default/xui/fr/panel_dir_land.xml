<panel label="Ventes foncières" name="panel_dir_land">
	<string name="searching_text">
		Recherche en cours...
	</string>
	<string name="not_found_text">
		Pas de résultats.
	</string>
	<string name="found_text">
		[COUNT] trouvé(s).
	</string>
	<text name="find">
		Termes de la recherche :
	</text>
	<combo_box name="type">
		<combo_item name="AllTypes" label="Toutes catégories"/>
		<combo_item name="Auction" label="Vente aux enchères"/>
		<combo_item name="MainlandSales" label="À vendre - Continent"/>
		<combo_item name="EstateSales" label="À vendre - Domaine"/>
	</combo_box>
	<icon tool_tip="Général" name="rating_icon_general"/>
	<icon tool_tip="Modéré" name="rating_icon_moderate"/>
	<icon tool_tip="Adulte" name="rating_icon_adult"/>
	<check_box label="Prix &#8804; " name="pricecheck"/>
	<check_box label="Surface &#8805; " name="areacheck"/>
	<button label="Recherche" name="Search"/>
	<scroll_list name="results">
		<column label="Nom" name="name" />
		<column label="Type" name="landtype"/>
		<column label="Prix L$" name="price"/>
		<column label="Surface" name="area"/>
		<column label="L$/m²" name="per_meter"/>
	</scroll_list>
	<button tool_tip="Page précédente" name="prev_btn"/>
	<button tool_tip="Page suivante" name="next_btn"/>
</panel>
