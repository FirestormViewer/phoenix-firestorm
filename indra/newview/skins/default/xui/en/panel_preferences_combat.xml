<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<panel
 border="true"
 follows="all"
 height="480"
 layout="topleft"
 left="1"
 top="1"
 width="540"
 label="Combat"
 name="combat">

    <!-- ===== Target identification ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top="10"
     width="520">
        Target Identification
    </text>
    <check_box
     control_name="FSMouselookCombatFeatures"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="16"
     label="Enable combat features"
     layout="topleft"
     left="10"
     name="FSMouselookCombatFeatures"
     top_pad="8"
     width="256" />
    <check_box
     control_name="ExodusMouselookIFF"
     follows="left|top"
     height="16"
     label="Draw target markers"
     layout="topleft"
     left="28"
     name="ExodusMouselookIFF"
     top_pad="5"
     width="256" />
    <slider
     control_name="ExodusMouselookIFFRange"
     follows="left|top"
     height="15"
     can_edit_text="true"
     decimal_digits="0"
     increment="5"
     layout="topleft"
     label="Range (m):"
     label_width="150"
     show_text="true"
     left="33"
     max_val="500"
     name="ExodusMouselookIFFRange"
     top_pad="5"
     width="333" />
    <check_box
     control_name="ExodusMouselookIFFLineOfSight"
     follows="left|top"
     height="16"
     label="Require line of sight to identify target"
     layout="topleft"
     left="28"
     name="ExodusMouselookIFFLineOfSight"
     tool_tip="Don't show the name of the avatar under your crosshair when walls, floors or terrain block the view"
     top_pad="5"
     width="256" />
    <check_box
     control_name="ExodusMouselookIFFShowName"
     follows="left|top"
     height="16"
     label="Show target name"
     layout="topleft"
     left="28"
     name="ExodusMouselookIFFShowName"
     tool_tip="Show the identified target's name under the crosshair. When off, identification still drives the crosshair color and combat feedback."
     top_pad="5"
     width="256" />

    <!-- ===== Hit marker and crosshair ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="14"
     width="520">
        Hit Marker and Crosshair
    </text>
    <check_box
     control_name="FSHitMarkerEnabled"
     follows="left|top"
     height="16"
     label="Hitmarker (flash + sound on hit)"
     layout="topleft"
     left="10"
     name="FSHitMarkerEnabledPref"
     tool_tip="Combat 2.0 regions, via the LSL bridge"
     top_pad="8"
     width="256" />
    <button
     follows="left|top"
     layout="topleft"
     left_delta="260"
     top_delta="-2"
     height="20"
     width="80"
     label="Options..."
     name="hit_marker_options_btn"
     tool_tip="Hitmarker, crosshair, hit report and sound options">
        <button.commit_callback
         function="Pref.HitMarkerSettings" />
    </button>

    <!-- ===== Kill feed ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="14"
     width="520">
        Kill Feed
    </text>
    <check_box
     control_name="FSKillFeedEnabled"
     follows="left|top"
     height="16"
     label="Show kill feed overlay"
     layout="topleft"
     left="10"
     name="kill_feed_enabled_pref"
     tool_tip="Region-wide Combat 2.0 death events as an on-screen feed (via the LSL bridge)"
     top_pad="8"
     width="256" />
    <button
     follows="left|top"
     layout="topleft"
     left_delta="260"
     top_delta="-2"
     height="20"
     width="80"
     label="Options..."
     name="kill_feed_options_btn"
     tool_tip="Kill feed position, size, font and color options">
        <button.commit_callback
         function="Pref.KillFeedSettings" />
    </button>

    <!-- ===== Mouselook Zoom ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="14"
     width="520">
        Mouselook Zoom
    </text>
    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="Mouse Sensitivity Zoomed Label"
     top_pad="8"
     width="230">
        Mouselook Zoomed Mouse Sensitivity:
    </text>
    <slider
     control_name="MouseSensitivityZoomed"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="15"
     initial_value="10"
     layout="topleft"
     show_text="true"
     can_edit_text="true"
     decimal_digits="0"
     left_pad="5"
     max_val="100"
     name="mouse_sensitivity_zoomed"
     tool_tip="Controls how sensitive the mouse is while zoomed in mouselook mode. Lower values make precision aiming easier; higher values allow faster turning. This is applied as a fraction or multiple of your base mouse sensitivity."
     top_delta="1"
     width="115" />
    <button
     follows="left|top"
     name="Def_MouseSensitivityZoomed"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-2"
     width="20"
     tool_tip="Reset to default value">
        <button.commit_callback
         function="ResetControl"
         parameter="MouseSensitivityZoomed"/>
    </button>
    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="MouselookZoomTransition Label"
     top_pad="12"
     width="230">
        Mouselook zoom transition:
    </text>
    <slider
     control_name="MouselookZoomTransitionSpeed"
     can_edit_text="true"
     decimal_digits="0"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="15"
     initial_value="0"
     layout="topleft"
     show_text="true"
     left_pad="5"
     max_val="1000"
     min_val="0"
     name="mouselook_zoom_transition_speed"
     tool_tip="Sets how long the field-of-view smoothly transitions when zooming in mouselook, in milliseconds. Set to 0 for instant snapping. Higher values produce a gradual cinematic zoom effect (up to 1000 ms via slider, or up to 5000 ms by typing a value directly)."
     top_delta="1"
     width="140" />
    <button
     follows="left|top"
     name="Def_MouselookZoomTransitionSpeed"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-2"
     width="20"
     tool_tip="Reset to default value">
        <button.commit_callback
         function="ResetControl"
         parameter="MouselookZoomTransitionSpeed"/>
    </button>

    <!-- ===== Aim down sights ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="14"
     width="300">
        Aim down sights
    </text>
    <check_box
     control_name="FSDoubleTapADS"
     follows="left|top"
     height="16"
     label="Enable double-tap right-click to ADS"
     layout="topleft"
     left="10"
     name="ads_enabled_prefs"
     top_pad="6"
     width="400"
     tool_tip="Tap, then tap-and-hold the right mouse button to aim down sights; release to exit. Works in first person and OTS." />
    <button
     follows="left|top"
     layout="topleft"
     left="448"
     top_delta="-2"
     height="20"
     width="80"
     label="Options..."
     name="ads_options_btn"
     tool_tip="Aim-down-sights field of view, smoothing, sensitivity and vignette options">
        <button.commit_callback
         function="Pref.ADSSettings" />
    </button>

    <!-- ===== Over-the-Shoulder camera ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="14"
     width="300">
        Over-the-Shoulder Camera
    </text>
    <check_box
     control_name="OTSEnabled"
     follows="left|top"
     height="16"
     label="Enable OTS Mode (active in mouselook)"
     layout="topleft"
     left="10"
     name="ots_enabled_prefs"
     top_pad="6"
     width="400" />
    <button
     follows="left|top"
     layout="topleft"
     left="448"
     top_delta="-2"
     height="20"
     width="80"
     label="Options..."
     name="ots_options_btn"
     tool_tip="Over-the-shoulder camera distance, offset, height, focus and behavior options">
        <button.commit_callback
         function="Pref.OTSSettings" />
    </button>

</panel>
