<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<floater
 positioning="cascading"
 can_minimize="false"
 can_resize="false"
 height="240"
 layout="topleft"
 name="floater_fs_ots_options"
 save_rect="true"
 single_instance="true"
 title="OVER-THE-SHOULDER CAMERA"
 width="430">
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="12"
     top="26"
     width="406">
        Over-the-Shoulder Camera
    </text>
    <slider
     control_name="OTSCameraDistance"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="3.0"
     layout="topleft"
     label="Distance (m):"
     label_width="130"
     show_text="true"
     left="12"
     max_val="10.0"
     min_val="0.5"
     name="OTSCameraDistancePref"
     top_pad="8"
     width="380" />
    <slider
     control_name="OTSCameraSide"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="-0.5"
     layout="topleft"
     label="Side Offset (m):"
     label_width="130"
     show_text="true"
     left="12"
     max_val="2.0"
     min_val="-2.0"
     name="OTSCameraSidePref"
     top_pad="8"
     width="380" />
    <slider
     control_name="OTSCameraHeight"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="0.5"
     layout="topleft"
     label="Height (m):"
     label_width="130"
     show_text="true"
     left="12"
     max_val="3.0"
     min_val="-1.0"
     name="OTSCameraHeightPref"
     top_pad="8"
     width="380" />
    <slider
     control_name="OTSFocusDistance"
     can_edit_text="true"
     decimal_digits="1"
     follows="left|top"
     height="15"
     initial_value="10.0"
     layout="topleft"
     label="Focus Distance (m):"
     label_width="130"
     show_text="true"
     left="12"
     max_val="50.0"
     min_val="2.0"
     name="OTSFocusDistancePref"
     top_pad="8"
     width="380" />
    <check_box
     control_name="OTSCameraCollision"
     follows="left|top"
     height="16"
     label="Camera collision (keep camera out of walls and floors)"
     layout="topleft"
     left="12"
     name="ots_camera_collision_prefs"
     tool_tip="Pull the camera in closer when world geometry is between you and it, instead of clipping through. Avatars and phantom objects never block the camera."
     top_pad="10"
     width="406" />
    <check_box
     control_name="FSOTSReportEyeCamera"
     follows="left|top"
     height="16"
     label="Convergence camera in OTS (scripts see your eye, not the shoulder camera)"
     layout="topleft"
     left="12"
     name="ots_eye_camera_prefs"
     tool_tip="While in OTS, report the mouselook-equivalent camera to the region so camera-position weapons fire from your avatar toward the crosshair instead of from the shoulder camera. Prevents shooting around cover your avatar is behind."
     top_pad="8"
     width="406" />
    <check_box
     control_name="OTSRememberLastView"
     follows="left|top"
     height="16"
     label="Remember last view (return to first person or OTS as last toggled)"
     layout="topleft"
     left="12"
     name="ots_remember_view_prefs"
     tool_tip="When entering aim mode, return to whichever view (over-the-shoulder or first person) you last switched to with the view toggle key, instead of always starting in OTS"
     top_pad="8"
     width="406" />
</floater>
