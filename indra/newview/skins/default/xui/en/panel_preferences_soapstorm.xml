<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<panel
 border="true"
 follows="all"
 height="480"
 layout="topleft"
 left="1"
 top="1"
 width="540"
 label="Soapstorm"
 name="soapstorm">

    <!-- ===== Mouselook Zoom ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top="10"
     width="520">
        Mouselook Zoom
    </text>

    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="Mouse Sensitivity Zoomed Label"
     top_pad="8"
     width="205">
        Mouselook zoomed sensitivity:
    </text>
    <slider
     control_name="MouseSensitivityZoomed"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="15"
     initial_value="10"
     layout="topleft"
     show_text="true"
     can_edit_text="true"
     decimal_digits="0"
     left_pad="5"
     max_val="100"
     name="mouse_sensitivity_zoomed"
     tool_tip="Controls how sensitive the mouse is while zoomed in mouselook mode. Lower values make precision aiming easier; higher values allow faster turning. This is applied as a fraction or multiple of your base mouse sensitivity."
     top_delta="1"
     width="140" />
    <button
     follows="left|top"
     name="Def_MouseSensitivityZoomed"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-2"
     width="20"
     tool_tip="Reset to default value">
        <button.commit_callback
         function="ResetControl"
         parameter="MouseSensitivityZoomed"/>
    </button>

    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="MouselookZoomTransition Label"
     top_pad="12"
     width="205">
        Mouselook zoom transition:
    </text>
    <slider
     control_name="MouselookZoomTransitionSpeed"
     can_edit_text="true"
     decimal_digits="0"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="15"
     initial_value="0"
     layout="topleft"
     show_text="true"
     left_pad="5"
     max_val="1000"
     min_val="0"
     name="mouselook_zoom_transition_speed"
     tool_tip="Sets how long the field-of-view smoothly transitions when zooming in mouselook, in milliseconds. Set to 0 for instant snapping. Higher values produce a gradual cinematic zoom effect (up to 1000 ms via slider, or up to 5000 ms by typing a value directly)."
     top_delta="1"
     width="165" />
    <button
     follows="left|top"
     name="Def_MouselookZoomTransitionSpeed"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-2"
     width="20"
     tool_tip="Reset to default value">
        <button.commit_callback
         function="ResetControl"
         parameter="MouselookZoomTransitionSpeed"/>
    </button>

    <!-- ===== Over-the-Shoulder Camera ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="18"
     width="520">
        Over-the-Shoulder Camera
    </text>

    <check_box
     control_name="OTSEnabled"
     follows="left|top"
     height="16"
     label="Enable OTS Mode (replaces Mouselook — M key)"
     layout="topleft"
     left="10"
     name="ots_enabled_prefs"
     top_pad="8"
     width="360" />
    <slider
     control_name="OTSCameraDistance"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="3.0"
     layout="topleft"
     label="Distance (m):"
     label_width="120"
     show_text="true"
     left="10"
     max_val="10.0"
     min_val="0.5"
     name="OTSCameraDistancePref"
     top_pad="5"
     width="333" />
    <slider
     control_name="OTSCameraSide"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="-0.5"
     layout="topleft"
     label="Side Offset (m):"
     label_width="120"
     show_text="true"
     left="10"
     max_val="2.0"
     min_val="-2.0"
     name="OTSCameraSidePref"
     top_pad="5"
     width="333" />
    <slider
     control_name="OTSCameraHeight"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="0.5"
     layout="topleft"
     label="Height (m):"
     label_width="120"
     show_text="true"
     left="10"
     max_val="3.0"
     min_val="-1.0"
     name="OTSCameraHeightPref"
     top_pad="5"
     width="333" />
    <slider
     control_name="OTSFocusDistance"
     can_edit_text="true"
     decimal_digits="1"
     follows="left|top"
     height="15"
     initial_value="10.0"
     layout="topleft"
     label="Focus Distance (m):"
     label_width="120"
     show_text="true"
     left="10"
     max_val="50.0"
     min_val="2.0"
     name="OTSFocusDistancePref"
     top_pad="5"
     width="333" />
    <check_box
     control_name="OTSCameraCollision"
     follows="left|top"
     height="16"
     label="Camera collision (keep camera out of walls and floors)"
     layout="topleft"
     left="10"
     name="ots_camera_collision_prefs"
     tool_tip="Pull the camera in closer when world geometry is between you and it, instead of clipping through. Avatars never block the camera."
     top_pad="8"
     width="360" />

</panel>
