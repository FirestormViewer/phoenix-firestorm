<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<panel
 border="true"
 follows="all"
 height="480"
 layout="topleft"
 left="1"
 top="1"
 width="540"
 label="Soapstorm"
 name="soapstorm">

    <!-- ===== Mouselook Zoom ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top="10"
     width="520">
        Mouselook Zoom
    </text>

    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="Mouse Sensitivity Zoomed Label"
     top_pad="8"
     width="205">
        Mouselook zoomed sensitivity:
    </text>
    <slider
     control_name="MouseSensitivityZoomed"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="15"
     initial_value="10"
     layout="topleft"
     show_text="true"
     can_edit_text="true"
     decimal_digits="0"
     left_pad="5"
     max_val="100"
     name="mouse_sensitivity_zoomed"
     tool_tip="Controls how sensitive the mouse is while zoomed in mouselook mode. Lower values make precision aiming easier; higher values allow faster turning. This is applied as a fraction or multiple of your base mouse sensitivity."
     top_delta="1"
     width="140" />
    <button
     follows="left|top"
     name="Def_MouseSensitivityZoomed"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-2"
     width="20"
     tool_tip="Reset to default value">
        <button.commit_callback
         function="ResetControl"
         parameter="MouseSensitivityZoomed"/>
    </button>

    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="MouselookZoomTransition Label"
     top_pad="12"
     width="205">
        Mouselook zoom transition:
    </text>
    <slider
     control_name="MouselookZoomTransitionSpeed"
     can_edit_text="true"
     decimal_digits="0"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="15"
     initial_value="0"
     layout="topleft"
     show_text="true"
     left_pad="5"
     max_val="1000"
     min_val="0"
     name="mouselook_zoom_transition_speed"
     tool_tip="Sets how long the field-of-view smoothly transitions when zooming in mouselook, in milliseconds. Set to 0 for instant snapping. Higher values produce a gradual cinematic zoom effect (up to 1000 ms via slider, or up to 5000 ms by typing a value directly)."
     top_delta="1"
     width="165" />
    <button
     follows="left|top"
     name="Def_MouselookZoomTransitionSpeed"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-2"
     width="20"
     tool_tip="Reset to default value">
        <button.commit_callback
         function="ResetControl"
         parameter="MouselookZoomTransitionSpeed"/>
    </button>

    <!-- ===== Over-the-Shoulder Camera ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="18"
     width="520">
        Over-the-Shoulder Camera
    </text>

    <check_box
     control_name="OTSEnabled"
     follows="left|top"
     height="16"
     label="Enable OTS Mode (replaces Mouselook — M key)"
     layout="topleft"
     left="10"
     name="ots_enabled_prefs"
     top_pad="8"
     width="360" />
    <slider
     control_name="OTSCameraDistance"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="3.0"
     layout="topleft"
     label="Distance (m):"
     label_width="120"
     show_text="true"
     left="10"
     max_val="10.0"
     min_val="0.5"
     name="OTSCameraDistancePref"
     top_pad="5"
     width="333" />
    <slider
     control_name="OTSCameraSide"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="-0.5"
     layout="topleft"
     label="Side Offset (m):"
     label_width="120"
     show_text="true"
     left="10"
     max_val="2.0"
     min_val="-2.0"
     name="OTSCameraSidePref"
     top_pad="5"
     width="333" />
    <slider
     control_name="OTSCameraHeight"
     can_edit_text="true"
     decimal_digits="2"
     follows="left|top"
     height="15"
     initial_value="0.5"
     layout="topleft"
     label="Height (m):"
     label_width="120"
     show_text="true"
     left="10"
     max_val="3.0"
     min_val="-1.0"
     name="OTSCameraHeightPref"
     top_pad="5"
     width="333" />
    <slider
     control_name="OTSFocusDistance"
     can_edit_text="true"
     decimal_digits="1"
     follows="left|top"
     height="15"
     initial_value="10.0"
     layout="topleft"
     label="Focus Distance (m):"
     label_width="120"
     show_text="true"
     left="10"
     max_val="50.0"
     min_val="2.0"
     name="OTSFocusDistancePref"
     top_pad="5"
     width="333" />

    <!-- ===== Viewer ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="18"
     width="520">
        Viewer
    </text>
    <check_box
     control_name="FSLocalLoginSplash"
     follows="left|top"
     height="16"
     label="Offline login screen (show an image instead of the web page)"
     layout="topleft"
     left="10"
     name="local_login_splash_prefs"
     tool_tip="Skip loading the web login page; takes effect the next time the login screen is shown"
     top_pad="8"
     width="500" />
    <text
     type="string"
     length="1"
     follows="left|top"
     height="14"
     layout="topleft"
     left="28"
     name="splash_image_label"
     top_pad="6"
     width="110">
        Background image:
    </text>
    <line_editor
     control_name="FSLocalLoginSplashImage"
     follows="left|top"
     layout="topleft"
     left_delta="114"
     top_delta="-3"
     height="20"
     width="300"
     name="splash_image_path"
     tool_tip="Full path to a PNG or JPG to use as the offline login background. Leave empty for the bundled crest." />
    <button
     follows="left|top"
     layout="topleft"
     left_delta="306"
     top_delta="0"
     height="20"
     width="64"
     label="Browse"
     name="splash_image_browse"
     tool_tip="Pick an image file for the offline login background">
        <button.commit_callback
         function="Pref.BrowseSplashImage" />
    </button>
    <check_box
     control_name="FSShowLoginLogo"
     follows="left|top"
     height="16"
     label="Show logo on the login screen"
     layout="topleft"
     left="10"
     name="show_login_logo_prefs"
     tool_tip="Show or hide the viewer logo next to the login fields"
     top_pad="8"
     width="500" />
    <text
     type="string"
     length="1"
     follows="left|top"
     height="14"
     layout="topleft"
     left="28"
     name="login_logo_label"
     top_pad="6"
     width="110">
        Logo image:
    </text>
    <line_editor
     control_name="FSLoginLogoImage"
     follows="left|top"
     layout="topleft"
     left_delta="114"
     top_delta="-3"
     height="20"
     width="300"
     name="login_logo_path"
     tool_tip="Full path to a PNG or JPG to replace the stock logo. Leave empty for the stock logo." />
    <button
     follows="left|top"
     layout="topleft"
     left_delta="306"
     top_delta="0"
     height="20"
     width="64"
     label="Browse"
     name="login_logo_browse"
     tool_tip="Pick an image file to replace the login screen logo">
        <button.commit_callback
         function="Pref.BrowseLoginLogo" />
    </button>
    <check_box
     control_name="FSNoUpdateReminders"
     follows="left|top"
     height="16"
     label="Don't remind me about optional updates"
     layout="topleft"
     left="10"
     name="no_update_reminders_prefs"
     tool_tip="Suppress optional update prompts. Required updates will still prompt, and automatic installation (if selected in Preferences) still works."
     top_pad="6"
     width="500" />

</panel>
