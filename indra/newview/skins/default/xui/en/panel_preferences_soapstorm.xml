<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<panel
 border="true"
 follows="all"
 height="480"
 layout="topleft"
 left="1"
 top="1"
 width="540"
 label="Soapstorm"
 name="soapstorm">

    <!-- ===== Mouselook Zoom ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top="10"
     width="520">
        Mouselook Zoom
    </text>

    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="Mouse Sensitivity Zoomed Label"
     top_pad="8"
     width="205">
        Mouselook zoomed sensitivity:
    </text>
    <slider
     control_name="MouseSensitivityZoomed"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="15"
     initial_value="10"
     layout="topleft"
     show_text="true"
     can_edit_text="true"
     decimal_digits="0"
     left_pad="5"
     max_val="100"
     name="mouse_sensitivity_zoomed"
     tool_tip="Controls how sensitive the mouse is while zoomed in mouselook mode. Lower values make precision aiming easier; higher values allow faster turning. This is applied as a fraction or multiple of your base mouse sensitivity."
     top_delta="1"
     width="140" />
    <button
     follows="left|top"
     name="Def_MouseSensitivityZoomed"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-2"
     width="20"
     tool_tip="Reset to default value">
        <button.commit_callback
         function="ResetControl"
         parameter="MouseSensitivityZoomed"/>
    </button>

    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="MouselookZoomTransition Label"
     top_pad="12"
     width="205">
        Mouselook zoom transition:
    </text>
    <slider
     control_name="MouselookZoomTransitionSpeed"
     can_edit_text="true"
     decimal_digits="0"
     follows="left|top"
     enabled_control="EnableMouselook"
     height="15"
     initial_value="0"
     layout="topleft"
     show_text="true"
     left_pad="5"
     max_val="1000"
     min_val="0"
     name="mouselook_zoom_transition_speed"
     tool_tip="Sets how long the field-of-view smoothly transitions when zooming in mouselook, in milliseconds. Set to 0 for instant snapping. Higher values produce a gradual cinematic zoom effect (up to 1000 ms via slider, or up to 5000 ms by typing a value directly)."
     top_delta="1"
     width="165" />
    <button
     follows="left|top"
     name="Def_MouselookZoomTransitionSpeed"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-2"
     width="20"
     tool_tip="Reset to default value">
        <button.commit_callback
         function="ResetControl"
         parameter="MouselookZoomTransitionSpeed"/>
    </button>

    <!-- ===== RMB Script Events ===== -->
    <text
     type="string"
     length="1"
     follows="left|top"
     font="SansSerifSmallBold"
     height="16"
     layout="topleft"
     left="10"
     top_pad="18"
     width="520">
        Right Mouse Button Script Events
    </text>

    <text
     type="string"
     length="1"
     follows="left|top"
     height="26"
     layout="topleft"
     left="10"
     top_pad="6"
     width="520">
        When in mouselook, right mouse button presses are sent to your attachments as LSL listen events on the configured channel.
    </text>

    <check_box
     control_name="FSRMBScriptEnabled"
     follows="left|top"
     height="16"
     label="Enable RMB script events in mouselook"
     layout="topleft"
     left="10"
     name="rmb_script_enabled"
     tool_tip="When checked, right mouse button presses in mouselook send RMBD/RMBU messages to your attachments on the channel below."
     top_pad="8"
     width="360" />

    <text
     type="string"
     length="1"
     follows="left|top"
     height="10"
     layout="topleft"
     left="10"
     name="RMBScriptChannelLabel"
     top_pad="10"
     width="80">
        Channel:
    </text>
    <line_editor
     control_name="FSRMBScriptChannel"
     enabled_control="FSRMBScriptEnabled"
     follows="left|top"
     height="19"
     layout="topleft"
     left_pad="5"
     max_length_bytes="12"
     name="rmb_script_channel"
     tool_tip="Negative channel number on which RMBD/RMBU events are sent to your attachments. Must be negative. Scripts listen with: llListen(channel, &quot;&quot;, NULL_KEY, &quot;&quot;)"
     top_delta="-4"
     width="100" />
    <button
     enabled_control="FSRMBScriptEnabled"
     follows="left|top"
     name="Def_FSRMBScriptChannel"
     height="20"
     label="D"
     layout="topleft"
     left_pad="2"
     top_delta="-1"
     width="20"
     tool_tip="Reset channel to default (-9999)">
        <button.commit_callback
         function="ResetControl"
         parameter="FSRMBScriptChannel"/>
    </button>

</panel>
