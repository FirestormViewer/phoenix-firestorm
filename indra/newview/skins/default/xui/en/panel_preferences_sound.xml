          width="90"
          name="media_autoplay_label">
        Media auto-play
      </text>
      <combo_box
          control_name="ParcelMediaAutoPlayEnable"
          enabled_control="AudioStreamingMedia"
          follows="left|top"
          layout="topleft"
          height="23"
          left_pad="7"
          top_delta="-4"
          name="media_auto_play_combo"
          width="100">
        <item
            label="Disabled"
            name="autoplay_disabled"
            value="0"/>
        <item
            label="Enabled"
            name="autoplay_enabled"
            value="1"/>
