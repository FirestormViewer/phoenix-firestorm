			<check_box label="Zənglər zamanı səs göstəricilərini göstər" tool_tip="Şəxsi və qrup zəngində səs göstəricisini göstərir" name="Show_Voice_Visualizers_In_Calls"/>
			<check_box label="Söhbət pəncərələrində səs kanallarının vəziyyətini göstər" tool_tip="Söhbət pəncərələrində səs kanallarının vəziyyətini göstərir" name="FSShowConversationVoiceStateIndicator"/>
