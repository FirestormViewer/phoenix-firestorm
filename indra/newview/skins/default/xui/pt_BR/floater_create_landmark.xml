<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater
 can_resize="false"
 show_title="true"
 can_minimize="false"
 can_close="false"
 height="305"
 layout="topleft"
 name="create_landmark"
 positioning="centered"
 title="Criar Marco"
 width="330">
  <string name="favorites_bar">
    Barra de favoritos
  </string>
    <text
     follows="left|top"
     height="15"
     layout="topleft"
     left="20"
     name="title_label"
     top="5"
     font="SansSerifLargeBold"
     value="Detalhes do Marco"
     width="290" />
    <text
     follows="left|top"
     height="15"
     layout="topleft"
     left="20"
     name="name_label"
     top_pad="10"
     value="Nome:"
     width="290" />
    <line_editor
     follows="left|top"
     height="22"
     layout="topleft"
     max_length_bytes="63"
     name="title_editor"
     prevalidator="ascii"
     text_readonly_color="white"
     top_pad="5"
     width="290" />
    <text
     follows="left|top"
     height="15"
     layout="topleft"
     name="folder_label"
     top_pad="10"
     value="Salvar este marco em:"
     width="290" />
    <combo_box
     follows="bottom|left"
     height="23"
     layout="topleft"
     name="folder_combo"
     top_pad="2"
     width="290" />
    <text
     follows="left|top"
     layout="topleft"
     top_pad="6"
     left="20"
     name="new_folder_textbox"
     height="20"
     parse_urls="true"
     skip_link_underline="true"
     wrap="true">
        [secondlife:/// Criar nova pasta]
    </text>
    <text
     follows="left|top"
     height="15"
     layout="topleft"
     name="notes_label"
     top_pad="10"
     value="Minhas notas:"
     width="290" />
    <text_editor
     bg_readonly_color="DkGray0"
     follows="all"
     height="75"
     layout="topleft"
     max_length="127"
     name="notes_editor"
     spellcheck="true"
     text_readonly_color="white"
     prevalidator="ascii_with_newline"
     commit_on_focus_lost="true"
     top_pad="5"
     width="290"
     wrap="true" />
    <button
     follows="bottom|left|right"
     height="23"
     label="OK"
     layout="topleft"
     mouse_opaque="false"
     name="ok_btn"
     top_pad="10"
     left="19"
     width="140" />
    <button
     follows="bottom|left|right"
     height="23"
     label="Cancelar"
     layout="topleft"
     left_pad="12"
     mouse_opaque="false"
     name="cancel_btn"
     width="140" />
</floater>