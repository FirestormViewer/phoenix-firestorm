<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<context_menu
  layout="topleft"
  name="Settings">
    <menu_item_check
     label="Sempre detalhe completo"
     layout="topleft"
     name="always_render">
        <on_click function="Settings.SetRendering" parameter="always"/>
        <on_check function="Settings.IsSelected" parameter="always" />
    </menu_item_check>
    <menu_item_check
     label="Nunca detalhe completo"
     layout="topleft"
     name="never_render">
        <on_click function="Settings.SetRendering" parameter="never"/>
        <on_check function="Settings.IsSelected" parameter="never" />
    </menu_item_check>
    <menu_item_check
     label="Remover das exceções"
     layout="topleft"
     name="default">
        <on_click function="Settings.SetRendering" parameter="default"/>
        <on_check function="Settings.IsSelected" parameter="default" />
        <on_visible function="Settings.IsSelected" parameter="non_default" />
  </menu_item_check>
  <menu_item_separator />
  <menu_item_call
  label="Inspecionar Avatar"
  name="inspect">
    <menu_item_call.on_click
     function="Avatar.Extended" parameter="inspect"/>
</menu_item_call>
  <menu_item_call
  label="Zoom no Avatar"
  tool_tip="Move a câmera para enquadrar este avatar."
  name="zoom">
    <menu_item_call.on_click
     function="Avatar.Extended" parameter="zoom"/>
</menu_item_call>
</context_menu>