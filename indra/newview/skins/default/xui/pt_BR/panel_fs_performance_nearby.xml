<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel bevel_style="none" follows="left|top|right" height="530" width="580" name="panel_performance_nearby" layout="topleft" left="0" top="0">
  <button height="16" width="16" layout="topleft" mouse_opaque="true" follows="left|top" name="back_btn" top="7" image_selected="Arrow_Left_Off" image_pressed="Arrow_Left_Off" image_unselected="Arrow_Left_Off" left="15" is_toggle="true">
  </button>
  <text follows="left|top" height="20" layout="topleft" left_pad="3" top="10" name="back_lbl" width="40">
    Voltar
  </text>
  <text follows="left|top" font="SansSerifLarge" text_color="White" height="20" layout="topleft" left="20" top_pad="10" name="av_nearby_title" width="205">
    Avatares próximos</text>
  <text follows="right|top" font="SansSerifLarge" text_color="White" height="20" layout="topleft" right="-40" top_delta="0" name="tot_av_count" halign="right" width="200">
   Total: 50 (120000.10μs)
  </text>
  <text follows="left|top" font="SansSerifSmall" text_color="White" height="18" layout="topleft" left="20" top_pad="5" name="av_nearby_desc" width="580">
    Oculte os avatares mais complexos para ganhar desempenho.
  </text>
  <slider control_name="IndirectMaxComplexity" visible="false" tool_tip="Controla em que ponto um avatar visualmente complexo é desenhado como impostor" follows="left|top" height="16" initial_value="101" increment="1" label="Complexidade máxima (K)" text_color="White" label_width="165" layout="topleft" min_val="1" max_val="101" name="IndirectMaxComplexity" show_text="false" top_pad="10" width="300">
  </slider>
  <text type="string" visible="false" length="1" follows="left|top" height="16" layout="topleft" top_delta="0" left_delta="304" text_color="White" name="IndirectMaxComplexityText" width="65">
    0
  </text>
  <slider control_name="RenderAvatarMaxART" tool_tip="Controla quando um avatar visualmente complexo é considerado demorando muito para renderizar (unidade: microssegundos)" follows="left|top" height="16" initial_value="4.7" increment="0.01" label="Tempo máximo de renderização (μs)" text_color="White" label_width="165" layout="topleft" min_val="2" max_val="4.7" name="FSRenderAvatarMaxART" show_text="false" left_delta="-304" top_delta="-16" width="490">
  </slider>
  <text type="string" length="1" follows="left|top" height="16" layout="topleft" top_delta="0" left_pad="5" text_color="White" name="FSRenderAvatarMaxARTText" width="65">
    sem limite
  </text>
  <name_list column_padding="1" draw_stripes="true" draw_heading="true" height="280" left="20" follows="left|top|right" layout="topleft" sort_column="art_value" short_names="false" name="nearby_list" name_column="name" top_pad="10" width="540">
    <name_list.columns label="" tool_tip="Gráfico de barras com o tempo de renderização atual (inclui ajuste automático) como porcentagem do mais lento." name="art_visual" width="90" />
    <name_list.columns label="Tempo (μs)" tool_tip="Tempo de renderização do avatar antes de qualquer ajuste automático (microssegundos)." name="art_value" width="80" />
    <name_list.columns label="Tempo aj. (μs)" tool_tip="Tempo de renderização do avatar após os ajustes (microssegundos)." name="adj_art_value" width="80" />
    <name_list.columns label="ARC" tool_tip="Complexidade (ARC) conforme regras padrão." name="complex_value" width="40" />
    <name_list.columns label="" tool_tip="Mostra ajustes: I=impostor, S=sem sombra." name="state" width="15" />
    <name_list.columns label="Nome" name="name" />
    <name_list.columns label="Detalhamento" tool_tip="Onde o tempo de renderização é gasto (Geom/Shad/outros)" name="breakdown" />
  </name_list>
  <text follows="left|top" font="SansSerifSmall" text_color="White" height="18" layout="topleft" left="20" top_pad="10" name="av_nearby_desc2" width="580">
     Você também pode clicar com o botão direito em um avatar no mundo para controlar a exibição.
  </text>
  <text follows="left|top" font="SansSerifSmall" text_color="White" height="18" layout="topleft" left="20" top_pad="0" name="av_nearby_desc3" width="580">
     Observação: seu próprio avatar inclui sobrecarga do visualizador. Use a aba de anexos para ver como você afeta os outros.
  </text>
  <text height="16" layout="topleft" name="AvatarComplexityMode_Label" top_delta="25" left="18" width="100">
     Exibição do avatar:
   </text>
  <combo_box control_name="RenderAvatarComplexityMode" follows="left|top" height="23" layout="topleft" left_pad="5" top_delta="-4" name="AvatarComplexityMode" width="200">
    <combo_box.item label="Limitar por complexidade" name="complexity_limit_everone" value="0" />
    <combo_box.item label="Sempre mostrar amigos" name="complexity_always_show_friends" value="1" />
    <combo_box.item label="Mostrar apenas amigos" name="complexity_only_show_friends" value="2" />
  </combo_box>
  <button height="23" label="Exceções..." layout="topleft" left="460" top_delta="0" name="exceptions_btn" width="100">
  </button>
  <view_border bevel_style="in" height="0" layout="topleft" name="border" top_pad="10" left="20" width="540" />
  <check_box height="16" initial_value="true" label="Ocultar avatares completamente." layout="topleft" name="hide_avatars" top_delta="15" left="18" width="280">
   </check_box>
  <text type="string" length="1" follows="left|top" height="15" layout="topleft" left="20" name="name_tags_textbox" top_pad="10" width="400">
    Etiquetas de nome:
  </text>
  <radio_group control_name="AvatarNameTagMode" height="20" layout="topleft" left="120" top_delta="0" name="name_tag_mode">
    <radio_item label="Desligado" name="radio" top_delta="20" layout="topleft" height="16" left="0" value="0" width="75" />
    <radio_item label="Ligado" left_pad="0" layout="topleft" top_delta="0" height="16" name="radio2" value="1" width="75" />
    <radio_item label="Mostrar brevemente" left_pad="0" name="radio3" height="16" layout="topleft" top_delta="0" value="2" width="160" />
  </radio_group>
</panel>
