<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="fs_import" help_topic="fs_import" title="Importar objeto" width="210" height="206" save_rect="true" can_resize="false" can_minimize="true" can_close="true">
  <floater.string name="floater_title">
		Importar [FILENAME]
	</floater.string>
  <floater.string name="file_status">
        [LINKSETS] conjuntos de links. [PRIMS] prims. [TEXTURES] texturas.
        [SOUNDS] sons. [ANIMATIONS] animações.
    </floater.string>
  <floater.string name="file_status_error">
        Erro ao ler o arquivo. Selecione outro arquivo.
    </floater.string>
  <floater.string name="file_version_error">
        Erro ao analisar arquivo, formato ou versão incorreta.
    </floater.string>
  <floater.string name="file_status_running">
        Conjunto de links [LINKSET] de [LINKSETS], prim [PRIM] de [PRIMS]
    </floater.string>
  <floater.string name="file_status_done">
        Importação concluída.
    </floater.string>
  <floater.string name="texture_uploading">
        Carregando textura [TEXTURE] de [TEXTURETOTAL].
    </floater.string>
  <floater.string name="sound_uploading">
        Carregando som [SOUND] de [SOUNDTOTAL].
    </floater.string>
  <floater.string name="animation_uploading">
        Carregando animação [ANIMATION] de [ANIMATIONTOTAL].
    </floater.string>
  <floater.string name="asset_uploading">
        Fazendo upload do ativo [ASSET] de [ASSETTOTAL].
    </floater.string>
  <floater.string name="upload_cost">
        Custo total dos uploads: L$ [COST].
    </floater.string>
  <floater.string name="object">
        objeto
    </floater.string>
  <floater.string name="objects">
        objetos
    </floater.string>
  <text type="string" length="1" follows="left|top" height="14" layout="topleft" left="5" name="filename_text" width="200">
		[FILENAME]
    </text>
  <text type="string" length="1" follows="left|top" height="14" layout="topleft" left="5" name="creation_date_text" width="200">
		Criado em [DATE_STRING]
    </text>
  <text type="string" length="1" follows="left|top" height="14" layout="topleft" left="5" name="author_text" use_ellipses="true" width="200">
		por [AUTHOR] [GRID]
    </text>
  <text type="string" length="1" follows="left|top" height="14" layout="topleft" left="5" name="client_text" use_ellipses="true" width="200">
		Cliente: [CLIENT] v.[VERSION]
    </text>
  <text type="string" length="1" follows="left|top" height="52" layout="topleft" left="5" name="file_status_text" width="200">
        Selecione um arquivo.
    </text>
  <check_box follows="top|left" height="16" layout="topleft" enabled="false" name="do_not_attach" label="Não anexe objeto" top_pad="5" />
  <check_box follows="top|left" height="16" layout="topleft" enabled="false" name="region_position" label="Restaurar posição da região" top_pad="1" />
  <check_box follows="top|left" height="16" layout="topleft" width="90" enabled="false" name="upload_asset" label="Carregar conteúdo" top_pad="1">
    <check_box.commit_callback function="Import.UploadAsset" />
  </check_box>
    <check_box follows="top|left" height="16" layout="topleft" top_pad="1" left_delta="15" enabled="false" name="temp_asset" label="Temporário">
    <check_box.commit_callback function="Import.TempAsset" />
  </check_box>
	<button name="import_btn" label="Importar" height="20" width="97" left="109" top_delta="-2" follows="right_bottom" />
  <loading_indicator visible="false" follows="left|top" height="18" layout="topleft" left="187" name="progress_indicator" top="110" width="18" />
</floater>
