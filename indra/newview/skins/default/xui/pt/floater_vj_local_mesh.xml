<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<floater name="Local Mesh"
  positioning="centered"
  legacy_header_height="18"
  can_resize="true"
  can_dock="false"
  can_close="true"
  height="305"
  width="505"
  min_width="505"
  min_height="300"
  layout="topleft"
  save_rect="true"
  save_visibility="true"
  single_instance="false"
  save_dock_state="false"
  help_topic="floater_local_mesh"
  title="Mesh Local">

  <tab_container name="local_mesh_tabs"
    follows="top|left|right|bottom"
    top="20"
    left="0"
    height="233"
    width="500"
    tab_position="top"
    enable_tabs_flashing="true"
    tabs_flashing_color="MenuItemFlashBgColor">
    <last_tab tab_top_image_flash="TabTop_Right_Flashing" />
    <panel name="local_mesh_assets_panel"
      follows="top|left|right|bottom"
      help_topic="local_mesh_assets"
      label="Ativos de mesh local"
      layout="topleft"
      title="Ativos de mesh local">
      <fs_scroll_list name="l_name_list"
        left_delta="5"
        top_pad="18"
        width="495"
        content_type="Objects"
        follows="left|top|right|bottom"
        column_padding="0"
        draw_heading="true"
        multi_select="true"
        search_column="1"
        visible="true">
        <column name="unit_status"
        label="Status"
        width="55" />
        <column name="unit_name"
        label="Nome"
        dynamicwidth="true" />
        <column name="unit_lods"
        label="LODs"
        width="55" />
        <column name="unit_objects"
        label="Objetos"
        width="55" />
        <column name="unit_id_HIDDEN"
        label="ID"
        width="0" />
      </fs_scroll_list>
    </panel>
    <panel name="logs_panel"
    follows="top|left|right|bottom"
    label="Registro"
    layout="topleft"
    help_topic="local_mesh_log">
      <view_border name="local_mesh_log_tab_border"
        bevel_style="none"
        follows="top|left|right|bottom"
        layout="topleft"
        left="3"
        ignore_tab="false"
        right="-2"
        top_pad="0"/>
      <text_editor name="local_mesh_log"
        max_length="65536"
        left_delta="0"
        top_delta="0"
        right="-2"
        follows="left|top|right|bottom"
        type="string"
        embedded_items="false"
        font="SansSerif"
        ignore_tab="false"
        layout="topleft"
        parse_urls="false"
        spellcheck="false"
        read_only="true"
        word_wrap="true">
      </text_editor>
    </panel>
    <panel name="local_mesh_settings_panel"
      follows="top|left|right|bottom"
      layout="topleft"
      label="Configurações"
      help_topic="local_mesh_settings">
      <view_border name="local_mesh_settings_tab_border"
        bevel_style="none"
        follows="top|left|right|bottom"
        layout="topleft"
        left="3"
        ignore_tab="false"
        right="-2"
        top_pad="0"
        width="619" />
      <check_box name="local_mesh_scale_use_meters"
        height="15"
        control_name="FSLocalMeshScaleAlwaysMeters"
        follows="top|left"
        top="8"
        left="8"
        width="220"
        label="Assumir escala em metros."
        tool_tip="Ignora unidades em centímetros usadas por ferramentas como o Maya." />
      <check_box name="checkbox_apply_joint_offsets"
        height="15"
        control_name="FSLocalMeshApplyJointOffsets"
        follows="top|left"
        top="28"
        left="8"
        width="220"
        label="Aplicar deslocamentos das juntas."
        tool_tip="Aplica deslocamentos de juntas definidos na mesh; por padrão são ignorados." />
      <check_box name="checkbox_auto_reload"
        height="15"
        control_name="FSLocalMeshAutoReload"
        follows="top|left"
        top="8"
        left="255"
        width="220"
        label="Recarregar arquivos alterados automaticamente."
        tool_tip="Monitora os arquivos de mesh locais no disco e recarrega quando houver alteração." />
      <text name="auto_reload_period_label"
        follows="left|top"
        layout="topleft"
        left="255"
        height="12"
        top="35"
        width="120">
          Intervalo de verificação (s):
      </text>
      <spinner name="auto_reload_period"
        control_name="FSLocalMeshAutoReloadPeriod"
        decimal_digits="2"
        increment="0.25"
        min_val="0.25"
        max_val="60"
        follows="left|top"
        layout="topleft"
        left="380"
        top="31"
        width="80"
        height="20"
        tool_tip="Com que frequência verificar alterações nos arquivos de mesh locais monitorados." />
      <text name="lod_suffix_label"
        follows="left|top"
        layout="topleft"
        left="8"
        height="12"
        top="53"
        width="110">
          Sufixos de LOD:
      </text>
      <combo_box name="lod_suffix_combo"
        height="18"
        follows="left|top"
        left="8"
        width="190"
        top="70"
        tool_tip="Escolha um padrão ou edite manualmente… || Padrão SL — (o mais baixo é LOD0, o alto sem sufixo). || Engine de jogos — Unity/UE5 etc. (mais baixo=LOD3, alto=LOD0). || Nomes de LOD — sufixos em inglês (mais baixo='LOWEST', alto='HIGH').">
        <combo_item name="choose_one">Atual</combo_item>
        <combo_item name="suff_sl">Padrão SL</combo_item>
        <combo_item name="suff_unity">Padrão de engines de jogo</combo_item>
        <combo_item name="suff_descriptive">Nomes de LOD</combo_item>
      </combo_box>
      <text name="suf_lowest_lab"
        follows="left|top"
        layout="topleft"
        left="8"
        height="12"
        top="98"
        halign="right"
        width="60">
          Mín.:
      </text>
      <line_editor name="suf_lowest"
        control_name="FSMeshLowestLodSuffix"
        border_style="line"
        border_thickness="1"
        follows="left|top"
        font="SansSerif"
        height="23"
        top="93"
        layout="topleft"
        left="73"
        max_length_chars="10"
        tool_tip="Sufixo usado para identificar o arquivo do LOD mais baixo no disco e os modelos correspondentes no arquivo."
        width="60" />
      <text name="suf_low_lab"
        follows="left|top"
        layout="topleft"
        halign="right"
        height="12"
        left="8"
        top="126"
        width="60">
        Baixo:
      </text>
      <line_editor name="suf_low"
        control_name="FSMeshLowLodSuffix"
        border_style="line"
        border_thickness="1"
        follows="left|top"
        font="SansSerif"
        height="23"
        top="121"
        layout="topleft"
        left="73"
        max_length_chars="10"
        tool_tip="Sufixo usado para identificar o arquivo LOD baixo no disco e os modelos correspondentes no arquivo."
        width="60" />
      <text name="suf_medium_lab"
        follows="left|top"
        left="8"
        top="154"
        layout="topleft"
        height="12"
        halign="right"
        width="60">
        Médio:
      </text>
      <line_editor name="suf_medium"
        control_name="FSMeshMediumLodSuffix"
        border_style="line"
        border_thickness="1"
        follows="left|top"
        font="SansSerif"
        height="23"
        top="149"
        layout="topleft"
        left="73"
        max_length_chars="10"
        tool_tip="Sufixo usado para identificar o arquivo LOD médio no disco e os modelos correspondentes no arquivo."
        width="60" />
      <text name="suf_high_lab"
        follows="left|top"
        layout="topleft"
        height="12"
        halign="right"
        left="8"
        top="182"
        width="60">
      Alto:
      </text>
      <line_editor name="suf_high"
        control_name="FSMeshHighLodSuffix"
        border_style="line"
        border_thickness="1"
        follows="left|top"
        font="SansSerif"
        height="23"
        top="177"
        layout="topleft"
        left="73"
        max_length_chars="10"
        tool_tip="Sufixo usado para identificar o arquivo LOD alto no disco e os modelos correspondentes no arquivo."
        width="60" />
      <text name="suf_physics_lab"
        follows="left|top"
        left="8"
        layout="topleft"
        height="12"
        halign="right"
        top="210"
        width="60">
        Física:
      </text>
      <line_editor name="suf_physics"
        control_name="FSMeshPhysicsSuffix"
        border_style="line"
        border_thickness="1"
        follows="left|top"
        font="SansSerif"
        height="23"
        top="205"
        layout="topleft"
        left="73"
        max_length_chars="10"
        tool_tip="Sufixo usado para identificar o arquivo de física no disco e os modelos correspondentes no arquivo."
        width="60" />
    </panel>
  </tab_container>
  <button name="btn_apply"
    height="18"
    label="Aplicar"
    layout="topleft"
    left="10"
    width="90"
    visible="true" />
  <combo_box name="object_apply_list"
    height="18"
    layout="topleft"
    follows="bottom"
    left="105"
    top_delta="0"
    width="315"
    visible="true" />
  <button name="btn_add"
    height="18"
    label="Adicionar"
    layout="topleft"
    left="10"
    width="90"
    visible="true" />
  <button name="btn_remove"
    height="18"
    label="Remover"
    layout="topleft"
    left="105"
    top_delta="0"
    width="90"
    visible="true" />
  <button name="btn_reload"
    height="18"
    label="Recarregar"
    layout="topleft"
    left="200"
    top_delta="0"
    width="90"
    visible="true"
    checkbox_control="FSLocalMeshAutoReload" />
  <button name="btn_clear"
    height="18"
    label="Limpar"
    layout="topleft"
    left="295"
    top_delta="0"
    width="90"
    visible="true" />
  <button name="btn_rez"
    height="18"
    label="Rezzar selecionado"
    tool_tip="Cria um objeto doador no mundo e preenche com o mesh local selecionado (objeto vazio no mundo)."
    layout="topleft"
    left="390"
    top_delta="0"
    width="90"
    visible="true" />
</floater>
