<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="sell land" title="Vender terreno">
	<scroll_container name="profile_scroll">
		<panel name="scroll_content_panel">
			<text name="info_parcel_label">
				Parcela:
			</text>
			<text name="info_parcel">
				NOME DA PARCELA
			</text>
			<text name="info_size_label">
				Tamanho:
			</text>
			<text name="info_size">
				[AREA] m².
			</text>
			<text name="info_action">
				Para vender esta parcela:
			</text>
			<text name="price_label">
				1. Definir preço:
			</text>
			<text name="price_text" >
				Digite o preço
			</text>
			<text name="price_ld">
				L$
			</text>
			<line_editor name="price">
				0
			</line_editor>
			<text name="price_per_m">
				([PER_METER] L$ por m²)
			</text>
			<text name="sell_to_label">
				2. Vender o terreno para:
			</text>
			<text name="sell_to_text">
				Venda aberta ou venda para pessoa específica?
			</text>
			<combo_box name="sell_to">
				<combo_box.item label="-- Selecionar --" name="--selectone--"/>
				<combo_box.item label="Qualquer pessoa" name="Anyone"/>
				<combo_box.item label="Pessoa específica:" name="Specificuser:"/>
			</combo_box>
			<button label="Selecionar" name="sell_to_select_agent"/>
			<text name="sell_objects_label">
				3. Vender os objetos junto com o terreno?
			</text>
			<text name="sell_objects_text">
				Os objetos transferíveis do proprietário do terreno na parcela mudarão de dono.
			</text>
			<radio_group name="sell_objects">
				<radio_item label="Não, manter os objetos" name="no"/>
				<radio_item label="Sim, vender objetos com o terreno" name="yes"/>
			</radio_group>
			<button label="Mostrar objetos" name="show_objects"/>
			<text name="nag_message_label">
				ATENÇÃO: Vendas são definitivas.
			</text>
			<button label="Colocar terreno à venda" name="sell_btn"/>
			<button label="Cancelar" name="cancel_btn"/>
		</panel>
	</scroll_container>
</floater>
