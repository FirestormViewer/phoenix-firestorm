		<text name="suggested_use_a_label">
			(Humanoide)
		</text>
		<text name="suggested_use_b_label">
			(Criatura)
		</text>
		<text name="suggested_use_c_label">
			(Mecânico)
		</text>
		<text name="suggested_use_d_label">
			(Outro)
