	<view name="controls_container">
	<button name="new_snapshot_btn" label="Atualizar"/>
	<panel name="advanced_options_panel">
		<text name="layer_type_label">
			Capturar:
		</text>
		<combo_box label="Camadas" name="layer_types">
			<combo_box.item label="Cores" name="Colors"/>
			<combo_box.item label="Profundidade" name="Depth"/>
			<combo_box.item label="Profundidade (24 bits)" name="Depth24"/>
		</combo_box>
		<check_box label="Mostrar moldura da captura" name="show_frame" tool_tip="Mostra uma moldura na área capturada. O que ficar fora fica dessaturado e levemente desfocado."/>
		<check_box label="Mostrar guias da moldura" name="show_guides" tool_tip="Mostra guias (regra dos terços) na área de captura."/>
		<button tool_tip="Abrir configurações da moldura" name="guide_settings_btn" width="20" left_pad="9"/>
		<check_box label="Interface" name="ui_check"/>
		<check_box label="Saldo em L$" name="currency_check"/>
		<check_box label="HUDs" name="hud_check"/>
		<check_box label="Congelar quadro (tela cheia)" name="freeze_frame_check"/>
		<check_box label="Atualizar automaticamente" name="auto_snapshot_check"/>
		<check_box label="Sem pós-processamento" name="no_post_check"/>
		<combo_box label="Filtro" name="filters_combobox" tool_tip="Filtro de imagem">
			<combo_box.item label="Sem filtro" name="NoFilter"/>
		</combo_box>
	</panel>
	<panel name="succeeded_panel">
		<text name="succeeded_lbl">
			Sucesso
		</text>
	</panel>
	<panel name="failed_panel">
		<text name="failed_lbl">
			Falhou
		</text>
	</panel>
	<text name="working_lbl">
		Aguarde
	</text>
	<text name="refresh_lbl">
		Atualize para salvar
	</text>
	</view>
	<text name="image_res_text">
		[WIDTH]px (largura) x [HEIGHT]px (altura)
	</text>
	<text name="file_size_label">
		[SIZE] KB
	</text>
	<button label="Foto 360°" name="360_label"/>
</floater>
