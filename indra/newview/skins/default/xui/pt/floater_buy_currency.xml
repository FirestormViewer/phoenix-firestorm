<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="buy currency" title="Comprar L$">
	<floater.string name="buy_currency">
		Comprar [LINDENS] L$ por aprox. [LOCALAMOUNT]
	</floater.string>
	<floater.string name="info_cannot_buy">
		Nao foi possivel comprar
	</floater.string>
	<layout_stack name="outer_stack">
		<layout_panel name="layout_panel_title">
			<text name="info_need_more">
				Voce precisa de mais L$
			</text>
			<text name="info_buying">
				Comprar L$
			</text>
		</layout_panel>
		<layout_panel name="layout_panel_price">
			<text name="target_price_label">
				Voce precisa de
			</text>
			<text name="target_price">
				[AMT] L$
			</text>
		</layout_panel>
		<layout_panel name="layout_panel_balance">
			<text name="balance_label">
				Voce tem agora
			</text>
			<text name="balance_amount">
				[AMT] L$
			</text>
		</layout_panel>
		<layout_panel name="layout_panel_required">
			<text name="required_label">
				Voce deve comprar pelo menos
			</text>
			<text name="required_amount">
				[AMT] L$
			</text>
		</layout_panel>
		<layout_panel name="layout_panel_action">
			<text name="currency_action">
				Escolha o valor para comprar
			</text>
			<text name="currency_label">
				L$
			</text>
			<line_editor label="L$" name="currency_amt">
				1234
			</line_editor>
			<text name="currency_est">
				Aprox. [LOCALAMOUNT]
			</text>
			<text name="getting_data">
				Calculando...
			</text>
			<text name="total_label">
				Seu novo saldo sera
			</text>
			<text name="total_amount">
				[AMT] L$
			</text>
		</layout_panel>
		<layout_panel name="layout_panel_msg">
			<text name="currency_links">
				[http://www.secondlife.com/my/account/payment_method_management.php forma de pagamento] | [https://www.secondlife.com/my/account/currency.php moeda]
			</text>
			<text name="exchange_rate_note">
				Digite o valor novamente para ver a taxa de cambio mais recente.
			</text>
			<text name="purchase_warning_repurchase">
				Depois de receber seus L$, tente a compra novamente.
			</text>
		</layout_panel>
		<layout_panel name="layout_panel_buttons">
			<text name="contacting">
				Entrando em contato com a LindeX...
			</text>
			<button label="Comprar agora" name="buy_btn"/>
			<button label="Cancelar" name="cancel_btn"/>
		</layout_panel>
	</layout_stack>
</floater>
