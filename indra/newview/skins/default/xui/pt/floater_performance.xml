<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater
 height="642"
 layout="topleft"
 name="performance"
 save_rect="true"
 reuse_instance="true"
 title="MELHORAR DESEMPENHO GRÁFICO"
 width="580">
  <string
   name="fps_text"
   value="quadros por segundo"/>
  <string
   name="max_text"
   value=" (máximo)"/>
  <panel
   bevel_style="none"
   follows="left|top"
   height="540"
   width="580"
   name="panel_top"
   visible="true"
   layout="topleft"
   left="0"   
   top="0">
    <panel
     bg_alpha_color="black"
     background_visible="true"
     background_opaque="false"
     border="false"
     bevel_style="none"
     follows="left|top"
     height="40"
     width="560"
     name="fps_subpanel"
     layout="topleft"
     left="10"
     top="5">
      <text
       follows="left|top"
       font="SansSerifHuge"
       text_color="White"
       height="20"
       layout="topleft"
       left="10"
       top="8"
       name="fps_value"
       width="42">
          167
      </text>
      <text
       follows="left|top"
       font="SansSerif"
       text_color="White"
       height="14"
       layout="topleft"
       left="55"
       top="8"
       name="fps_label"
       width="90">
          fps
      </text>
      <text
       type="string"
       follows="left|top"
       font="SansSerif"
       text_color="White"
       height="14"
       layout="topleft"
       left="150"
       top="8"
       name="sim_fps_label"
       width="120">
          (simulado)
      </text>
      <text
       follows="left|top"
       font="SansSerif"
       height="14"
       layout="topleft"
       left="280"
       top="8"
       name="sim_fps_value"
       width="42">
          167
      </text>
      <text
       follows="left|top"
       font="SansSerifHuge"
       text_color="White"
       height="20"
       layout="topleft"
       left="330"
       top="8"
       name="drawwords"
       width="70">
          desenhar
      </text>
      <text
       follows="left|top"
       font="SansSerif"
       text_color="White"
       height="14"
       layout="topleft"
       left="410"
       top="8"
       name="draw_label"
       width="130">
          palavras por quadro
      </text>
     </panel>
     <view_border
      bevel_style="in"
      follows="left|right|top"
      height="2"
      layout="topleft"
      left="10"
      top="48"
      right="-10"
      name="divider1"/>
     <panel
      follows="left|right|top"
      height="30"
      layout="topleft"
      left="10"
      name="controls"
      top="55">
      <button
       follows="left|top"
       height="20"
       layout="topleft"
       left="1"
       name="chk_vsync"
       width="90">
      <button.on_check
       function="Preferences.DeferredApplyFeature"
       parameter="UseVsync"/>
      </button>
      <button
       follows="left|top"
       height="20"
       layout="topleft"
       left="90"
       name="chk_others"
       width="80">
      <button.on_check
       function="Preferences.DeferredApplyFeature"
       parameter="RenderUI"/>
      </button>
      <button
       follows="left|top"
       height="20"
       layout="topleft"
       left="170"
       name="chk_reflections"
       width="90">
      <button.on_check
       function="Preferences.DeferredApplyFeature"
       parameter="RenderReflection"/>
      </button>
      <button
       follows="left|top"
       height="20"
       layout="topleft"
       left="260"
       name="chk_shadows"
       width="80">
      <button.on_check
       function="Preferences.DeferredApplyFeature"
       parameter="RenderDeferredShadow"/>
      </button>
      <button
       follows="left|top"
       height="20"
       layout="topleft"
       left="340"
       name="chk_hero"
       width="120">
      <button.on_check
       function="CheckHero"
       parameter="Hero"/>
      </button>
      <button
       follows="left|top"
       height="20"
       layout="topleft"
       left="460"
       name="chk_wind"
       width="90">
      <button.on_check
       function="Preferences.DeferredApplyFeature"
       parameter="Wind"/>
      </button>
     </panel>
     <panel
      follows="left|right|top|bottom"
      name="main_panel"
      layout="topleft"
      left="10"
      top="90"
      right="-10"
      bottom="-10">
      <scroll_list
       draw_heading="true"
       name="settings_list"
       layout="topleft"
       left="0"
       top="0"
       right="-1"
       bottom="-1"
       multi_select="false">
        <scroll_list.heading
         label="Configuração"
         name="col_name"
         width="180"/>
        <scroll_list.heading
         label="Atual"
         name="col_cur_value"
         width="80"/>
        <scroll_list.heading
         label="Padrão"
         name="col_default_value"
         width="80"/>
        <scroll_list.heading
         label="Mín."
         name="col_min_value"
         width="80"/>
        <scroll_list.heading
         label="Máx."
         name="col_max_value"
         width="80"/>
      </scroll_list>
     </panel>
    </panel>
</floater>