<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="Image Preview" title="">
	<string name="with_alpha">
		com alpha
	</string>
	<string name="no_alpha">
		sem alpha
	</string>
	<text name="name_label">
		Nome:
	</text>
	<text name="description_label">
		Descrição:
	</text>
	<text name="preview_label">
		Visualizar como:
	</text>
	<combo_box label="Tipo de vestível" name="clothing_type_combo">
		<item label="Imagem" name="Image" value="Imagem"/>
		<item label="Cabelo" name="Hair" value="Cabelo"/>
		<item label="Cabeça (feminino)" name="FemaleHead" value="Cabeça (feminino)"/>
		<item label="Parte superior (feminino)" name="FemaleUpperBody" value="Parte superior (feminino)"/>
		<item label="Parte inferior (feminino)" name="FemaleLowerBody" value="Parte inferior (feminino)"/>
		<item label="Cabeça (masculino)" name="MaleHead" value="Cabeça (masculino)"/>
		<item label="Parte superior (masculino)" name="MaleUpperBody" value="Parte superior (masculino)"/>
		<item label="Parte inferior (masculino)" name="MaleLowerBody" value="Parte inferior (masculino)"/>
		<item label="Saia" name="Skirt" value="Saia"/>
		<item label="Prim esculpido" name="SculptedPrim" value="Prim esculpido"/>
	</combo_box>
	<panel name="image_alpha_warning">
		<check_box name="strip_alpha_check" label="Canal alpha vazio será removido"/>
	</panel>
	<text name="bad_image_text">
		Não foi possível ler a imagem.

Salve a imagem como Targa de 24 bits (.tga).
	</text>
	<text name="uploaded_size_text">
		Tamanho enviado: [X_RES]x[Y_RES], [ALPHA]
	</text>
	<check_box label="Compressão sem perdas" name="lossless_check" left_delta="-5"/>
	<check_box name="temp_check" label="Temporário (grátis)" tool_tip="Envia a imagem temporariamente, ou seja, o upload é gratuito. Em contrapartida, ela será excluída automaticamente após algum tempo." />
	<button label="Enviar ([AMOUNT] L$)" name="ok_btn" width="146"/>
	<button label="Cancelar" name="cancel_btn"/>
</floater>
