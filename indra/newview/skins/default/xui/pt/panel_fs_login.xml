<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel name="panel_login">
	<panel.string name="create_account_url">
		http://de.secondlife.com/registration/
	</panel.string>
	<panel.string name="forgot_password_url">
		http://secondlife.com/account/request.php?lang=pt
	</panel.string>
	<string name="ServerComboTooltip">
		Um grid conhecido ou URI do grid
	</string>
	<layout_stack name="login_widgets">
		<layout_panel name="login">
			<text name="log_in_text">
				ENTRAR
			</text>
			<text name="username_text">
				Nome de usuário:
			</text>
			<combo_box name="username_combo" tool_tip="Nome de usuário escolhido no cadastro, como berndschmidt12 ou Nome Sobrenome"/>
			<button tool_tip="Excluir este nome de usuário" name="remove_user_btn"/>
			<text name="password_text">
				Senha:
			</text>
		</layout_panel>
		<layout_panel name="start_location_panel">
			<text name="start_location_text">
				Iniciar em:
			</text>
			<combo_box name="start_location_combo">
				<combo_box.item label="Último local" name="MyLastLocation"/>
				<combo_box.item label="Casa" name="MyHome"/>
				<combo_box.item label="&lt;Digite a região&gt;" name="Typeregionname"/>
			</combo_box>
		</layout_panel>
		<layout_panel name="grid_panel">
			<text name="grid_builder_text">
				+ Clique para adicionar grids
			</text>
			<text name="grid_login_text">
				Seleção de grid:
			</text>
		</layout_panel>
		<layout_panel name="links_login_panel">
			<text name="create_new_account_text">
				Cadastrar
			</text>
			<text name="forgot_password_text">
				Esqueceu usuário ou senha?
			</text>
			<button label="Entrar" name="connect_btn"/>
			<check_box label="Salvar nome de usuário" name="remember_username_check"/>
			<check_box label="Salvar senha" name="remember_check"/>
			<button name="password_show_btn" tool_tip="Mostrar senha"/>
			<button name="password_hide_btn" tool_tip="Ocultar senha"/>
		</layout_panel>
		<layout_panel name="mode_selection">
			<text name="mode_selection_text">
				MODO
			</text>
			<combo_box name="mode_combo" tool_tip="Escolha o estilo de viewer mais familiar para ajustar os padrões às suas necessidades.">
				<combo_box.item label="Hybrid" name="Hybrid"/>
				<combo_box.item label="Text" name="Text"/>
			</combo_box>
		</layout_panel>
	</layout_stack>
</panel>
