<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="money_tracker" title="Rastreador de dinheiro">
	<name_list name="payment_list">
		<name_list.columns name="time" label="Hora"/>
		<name_list.columns name="name" label="Nome"/>
		<name_list.columns name="amount" label="Valor"/>
	</name_list>
	<text name="summary">
		Pago: L$ [PAID] - Recebido: L$ [RECEIVED]
	</text>
	<check_box label="Registrar sempre" name="FSAlwaysTrackPayments" tool_tip="Registrar pagamentos mesmo com o rastreador fechado."/>
	<button name="Clear" label="Excluir"/>
</floater>
