<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="floater_about" title="Navegador de mídia">
	<floater.string name="home_page_url">
		http://de.secondlife.com
	</floater.string>
	<floater.string name="support_page_url">
		http://de.secondlife.com/support
	</floater.string>
	<layout_stack name="stack1">
		<layout_panel name="nav_controls">
			<button label="Voltar" name="back"/>
			<button label="Avançar" name="forward"/>
			<button label="Recarregar" name="reload"/>
			<button label="Ir" name="go"/>
		</layout_panel>
		<layout_panel name="time_controls">
			<button label="retroceder" name="rewind" width="100"/>
			<button label="parar" name="stop" left_pad="20"/>
			<button label="avançar" name="seek"/>
		</layout_panel>
		<layout_panel name="parcel_owner_controls">
			<button label="Enviar página atual para a parcela" name="assign"/>
		</layout_panel>
		<layout_panel name="external_controls">
			<text name="plugin_fail_text">
O plugin do navegador de mídia está demorando para carregar.
Se o plugin não carregar, consulte as informações para resolver o problema em

https://wiki.firestormviewer.org/fs_media
			</text>
			<button label="Abrir no meu navegador" name="open_browser"/>
			<check_box label="Sempre abrir no meu navegador" name="open_always"/>
			<button label="Fechar" name="close"/>
		</layout_panel>
	</layout_stack>
</floater>
