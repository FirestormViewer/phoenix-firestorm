<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="experience_profile" title="Perfil da experiencia">
	<floater.string name="empty_slurl">
		(nenhum)
	</floater.string>
	<floater.string name="maturity_icon_general">
		&quot;Parcel_PG_Light&quot;
	</floater.string>
	<floater.string name="maturity_icon_moderate">
		&quot;Parcel_M_Light&quot;
	</floater.string>
	<floater.string name="maturity_icon_adult">
		&quot;Parcel_R_Light&quot;
	</floater.string>
	<text name="edit_title" value="Perfil da experiencia"/>
	<tab_container name="tab_container">
		<panel name="panel_experience_info">
			<scroll_container name="xp_scroll">
				<panel name="scrolling_panel">
					<layout_stack name="ls1">
						<layout_panel name="top panel">
							<button label="Editar" name="edit_btn"/>
						</layout_panel>
						<layout_panel name="maturity panel">
							<text name="ContentRating">
								Classificacao:
							</text>
						</layout_panel>
						<layout_panel name="location panel">
							<text name="Location">
								Local:
							</text>
						</layout_panel>
						<layout_panel name="marketplace panel">
							<text name="Marketplace">
								Loja do Marketplace:
							</text>
						</layout_panel>
						<layout_panel name="owner panel">
							<text name="Owner">
								Proprietario:
							</text>
						</layout_panel>
						<layout_panel name="group_panel">
							<text name="Group">
								Grupo:
							</text>
						</layout_panel>
						<layout_panel name="perm panel">
							<button label="Permitir" name="allow_btn"/>
							<button label="Esquecer" name="forget_btn"/>
							<button label="Bloquear" name="block_btn"/>
							<text name="privileged">
								Esta experiencia esta habilitada para todos os residentes.
							</text>
							<button label="Denunciar abuso" name="report_btn" width="114" left="97"/>
						</layout_panel>
					</layout_stack>
				</panel>
			</scroll_container>
		</panel>
		<panel name="edit_panel_experience_info">
			<scroll_container name="edit_xp_scroll">
				<panel name="edit_scrolling_panel">
					<text name="edit_experience_title_label" value="Nome:"/>
					<text name="edit_experience_desc_label" value="Descricao:"/>
					<button label="Grupo" name="Group_btn"/>
					<text name="edit_ContentRating">
						Classificacao:
					</text>
					<icons_combo_box label="Moderado" name="edit_ContentRatingText" tool_tip="Aumentar a classificacao de maturidade de uma experiencia redefinira a permissao de todos os residentes que a autorizaram.">
						<icons_combo_box.item label="Adulto" name="Adult" value="42"/>
						<icons_combo_box.item label="Moderado" name="Mature" value="21"/>
						<icons_combo_box.item label="Geral" name="PG" value="13"/>
					</icons_combo_box>
					<text name="edit_Location">
						Local:
					</text>
					<button label="Usar local atual" name="location_btn"/>
					<button label="Limpar local" name="clear_btn"/>
					<text name="edit_marketplace">
						Loja do Marketplace:
					</text>
					<check_box label="Ativar experiencia" name="edit_enable_btn" tool_tip=""/>
					<check_box label="Ocultar na busca" name="edit_private_btn"/>
					<text name="changes" value="As alteracoes da experiencia podem levar varios minutos para aparecer em todas as regioes."/>
					<button label="Voltar" name="cancel_btn"/>
					<button label="Salvar" name="save_btn"/>
				</panel>
			</scroll_container>
		</panel>
	</tab_container>
</floater>
