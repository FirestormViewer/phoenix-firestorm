<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<toggleable_menu name="Chat Options Menu" opaque="true" visible="false">
	<menu_item_check
		label="Mostrar Radar..."
		name="nearby_people">
		<menu_item_check.on_click
			function="Floater.Toggle"
			parameter="fs_radar"/>
		<menu_item_check.on_check
			function="Floater.Visible"
			parameter="fs_radar"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar Voz Próxima..."
		name="nearby_voice">
		<menu_item_check.on_click
			function="Floater.Toggle"
			parameter="fs_voice_controls"/>
		<menu_item_check.on_check
			function="Floater.Visible"
			parameter="fs_voice_controls"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar Lista de Bloqueio..."
		name="block_list">
		<menu_item_check.on_click
			function="ChatOptions.Action"
			parameter="blocklist"/>
		<menu_item_check.on_check
			function="ChatOptions.Check"
			parameter="blocklist"/>
	</menu_item_check>
	<menu_item_separator/>
	<menu_item_check
		label="Usar estilo de cabeçalho de chat V1"
		name="plain_text_chat_history">
		<menu_item_check.on_check
			function="CheckControl"
			parameter="PlainTextChatHistory"/>
		<menu_item_check.on_click
			function="ToggleControl"
			parameter="PlainTextChatHistory"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar ícones de perfil nos cabeçalhos"
		name="chat_header_icons">
		<menu_item_check.on_check
			function="CheckControl"
			parameter="ShowChatMiniIcons"/>
		<menu_item_check.on_click
			function="ToggleControl"
			parameter="ShowChatMiniIcons"/>
		<menu_item_check.on_visible
			function="ChatOptions.Visible"
			parameter="show_mini_icons"/>
	</menu_item_check>
	<context_menu
		label="Tamanho da fonte..."
		name="font_size">
		<menu_item_check
			label="Pequeno"
			name="font_size_small">
			<menu_item_check.on_check
				function="ChatOptions.Check"
				parameter="font_size_small"/>
			<menu_item_check.on_click
				function="ChatOptions.Action"
				parameter="font_size_small"/>
		</menu_item_check>
		<menu_item_check
			label="Médio"
			name="font_size_medium">
			<menu_item_check.on_check
				function="ChatOptions.Check"
				parameter="font_size_medium"/>
			<menu_item_check.on_click
				function="ChatOptions.Action"
				parameter="font_size_medium"/>
		</menu_item_check>
		<menu_item_check
			label="Grande"
			name="font_size_large">
			<menu_item_check.on_check
				function="ChatOptions.Check"
				parameter="font_size_large"/>
			<menu_item_check.on_click
				function="ChatOptions.Action"
				parameter="font_size_large"/>
		</menu_item_check>
		<menu_item_check
			label="Enorme"
			name="font_size_huge">
			<menu_item_check.on_check
				function="ChatOptions.Check"
				parameter="font_size_huge"/>
			<menu_item_check.on_click
				function="ChatOptions.Action"
				parameter="font_size_huge"/>
		</menu_item_check>
	</context_menu>
	<menu_item_separator/>
	<menu_item_check
		label="Mostrar indicador de digitação (&gt;)"
		name="typing_chevron">
		<menu_item_check.on_check
			function="CheckControl"
			parameter="FSTypingChevronPrefix"/>
		<menu_item_check.on_click
			function="ToggleControl"
			parameter="FSTypingChevronPrefix"/>
		<menu_item_check.on_visible
			function="ChatOptions.Visible"
			parameter="typing_chevron"/>
		<menu_item_check.on_enable
			function="ChatOptions.Enable"
			parameter="typing_chevron"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar notificação de nova mensagem"
		name="new_message_notification">
		<menu_item_check.on_check
			function="ChatOptions.Check"
			parameter="new_message_notification"/>
		<menu_item_check.on_click
			function="ChatOptions.Action"
			parameter="new_message_notification"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar barra de chat"
		name="show_chat_bar">
		<menu_item_check.on_check
			function="CheckControl"
			parameter="FSNearbyChatbar"/>
		<menu_item_check.on_click
			function="ToggleControl"
			parameter="FSNearbyChatbar"/>
		<menu_item_check.on_visible
			function="ChatOptions.Visible"
			parameter="show_chat_bar"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar seleção de canal"
		name="show_channel_selection">
		<menu_item_check.on_check
			function="CheckControl"
			parameter="FSShowChatChannel"/>
		<menu_item_check.on_click
			function="ToggleControl"
			parameter="FSShowChatChannel"/>
		<menu_item_check.on_visible
			function="ChatOptions.Visible"
			parameter="show_channel_selection"/>
		<menu_item_check.on_enable
			function="ChatOptions.Enable"
			parameter="show_channel_selection"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar botão de emoji"
		name="show_emoji_button">
		<menu_item_check.on_check
			function="CheckControl"
			parameter="FSShowEmojiButton"/>
		<menu_item_check.on_click
			function="ToggleControl"
			parameter="FSShowEmojiButton"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar botão de enviar do chat"
		name="show_send_button">
		<menu_item_check.on_check
			function="CheckControl"
			parameter="FSShowChatType"/>
		<menu_item_check.on_click
			function="ToggleControl"
			parameter="FSShowChatType"/>
		<menu_item_check.on_visible
			function="ChatOptions.Visible"
			parameter="show_send_button"/>
		<menu_item_check.on_enable
			function="ChatOptions.Enable"
			parameter="show_send_button"/>
	</menu_item_check>
	<menu_item_check
		label="Mostrar botão de enviar nas sessões de IM"
		name="show_im_send_button">
		<menu_item_check.on_check
			function="CheckControl"
			parameter="FSShowIMSendButton"/>
		<menu_item_check.on_click
			function="ToggleControl"
			parameter="FSShowIMSendButton"/>
		<menu_item_check.on_visible
			function="ChatOptions.Visible"
			parameter="show_im_send_button"/>
	</menu_item_check>
</toggleable_menu>
