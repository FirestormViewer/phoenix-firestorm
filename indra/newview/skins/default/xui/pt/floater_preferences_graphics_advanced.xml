<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="prefs_graphics_advanced" title="Preferências gráficas avançadas">
	<text name="GeneralText">
		Geral
	</text>
	<slider label="Distância de renderização:" name="DrawDistance"/>
	<text name="DrawDistanceMeterText2">
		m
	</text>
	<slider label="Máx. de partículas:" name="MaxParticleCount"/>
	<slider label="Qualidade pós-processamento:" name="RenderPostProcess"/>
	<text name="PostProcessText">
		Baixa
	</text>
	<text name="AvatarText">
		Avatar
	</text>
	<slider label="Complexidade máxima:" name="IndirectMaxComplexity" tool_tip="Define em que ponto um avatar visualmente complexo é exibido como JellyDoll"/>
	<text name="IndirectMaxComplexityText">
		0
	</text>
	<slider label="Máx. de avatares totalmente renderizados:" name="IndirectMaxNonImpostors"/>
	<text name="IndirectMaxNonImpostorsText">
		0
	</text>
	<slider label="Detalhes:" name="AvatarMeshDetail"/>
	<text name="AvatarMeshDetailText">
		Baixo
	</text>
	<slider label="Física:" name="AvatarPhysicsDetail"/>
	<text name="AvatarPhysicsDetailText">
		Baixo
	</text>
	<text name="HardwareText">
		Hardware
	</text>
	<slider label="Cache de texturas (MB):" name="GraphicsCardTextureMemory" tool_tip="Memória disponível para texturas. Geralmente é memória da placa de vídeo. Um valor menor pode aumentar a velocidade, mas também causar texturas borradas."/>
	<slider label="Proporção da distância de névoa:" name="fog"/>
	<slider label="Gama:" name="gamma"/>
	<text name="(brightness, lower is brighter)">
		(0 = brilho padrão, menor = mais claro)
	</text>
	<check_box label="Filtragem anisotrópica (mais lenta quando ativada)" name="ani"/>
	<check_box initial_value="true" label="Ativar objetos de buffer de vértices OpenGL" name="vbo" tool_tip="Se você tem hardware gráfico moderno, ativar esta opção pode melhorar a velocidade. Em hardware antigo, VBOs costumam ser mal implementados e podem causar travamentos quando esta opção está ativada."/>
	<check_box initial_value="true" label="Ativar compressão de texturas (requer reinício)" name="texture compression" tool_tip="Comprime texturas na memória de vídeo para permitir texturas de resolução mais alta (com leve perda de qualidade de cor)."/>
	<check_box initial_value="true" label="Ativar suporte a displays HiDPI (requer reinício)" name="use HiDPI" tool_tip="Ativar OpenGL para renderização em alta resolução."/>
	<text name="antialiasing label">
		Antialiasing:
	</text>
	<combo_box label="Antialiasing" name="fsaa">
		<combo_box.item label="Desativado" name="FSAADisabled"/>
		<combo_box.item label="2x" name="2x"/>
		<combo_box.item label="4x" name="4x"/>
		<combo_box.item label="8x" name="8x"/>
		<combo_box.item label="16x" name="16x"/>
	</combo_box>
	<text name="antialiasing restart">
		(requer reinício)
	</text>
	<text name="MeshText">
		Malha
	</text>
	<slider label="Detalhes da malha do terreno:" name="TerrainMeshDetail"/>
	<text name="TerrainMeshDetailText">
		Baixo
	</text>
	<slider label="Árvores:" name="TreeMeshDetail"/>
	<text name="TreeMeshDetailText">
		Baixo
	</text>
	<slider label="Objetos:" name="ObjectMeshDetail"/>
	<text name="ObjectMeshDetailText">
		Baixo
	</text>
	<slider label="Flexiprims:" name="FlexibleMeshDetail"/>
	<text name="FlexibleMeshDetailText">
		Baixo
	</text>
	<text name="ShadersText">
		Shaders
	</text>
	<check_box initial_value="true" label="Água transparente" name="TransparentWater"/>
	<check_box initial_value="true" label="Bump mapping e brilho" name="BumpShiny"/>
	<check_box initial_value="true" label="Fontes de luz locais" name="LocalLights"/>
	<slider label="Detalhes do terreno:" name="TerrainDetail"/>
	<text name="TerrainDetailText">
		Baixo
	</text>
	<check_box initial_value="true" label="Cálculo de pele por hardware para avatar" name="AvatarVertexProgram"/>
	<check_box initial_value="true" label="Roupas do avatar" name="AvatarCloth"/>
	<text name="ReflectionsText">
		Reflexos na água:
	</text>
	<combo_box name="Reflections">
		<combo_box.item label="Mínimo" name="0"/>
		<combo_box.item label="Terreno e árvores" name="1"/>
		<combo_box.item label="Todos os objetos estáticos" name="2"/>
		<combo_box.item label="Todos os avatares e objetos" name="3"/>
		<combo_box.item label="Tudo" name="4"/>
	</combo_box>
	<check_box initial_value="true" label="Shaders atmosféricos" name="WindLightUseAtmosShaders"/>
	<slider label="Céu:" name="SkyMeshDetail"/>
	<text name="SkyMeshDetailText">
		Baixo
	</text>
	<check_box initial_value="true" label="Modelo de iluminação avançado" name="UseLightShaders"/>
	<check_box initial_value="true" label="Oclusão ambiente" name="UseSSAO"/>
	<check_box initial_value="true" label="Profundidade de campo" name="UseDoF"/>
	<text name="RenderShadowDetailText">
		Sombras:
	</text>
	<combo_box name="ShadowDetail">
		<combo_box.item label="Nenhuma" name="0"/>
		<combo_box.item label="Sol/Lua" name="1"/>
		<combo_box.item label="Sol/Lua + projetores" name="2"/>
	</combo_box>
	<button label="Restaurar configurações recomendadas" name="Defaults"/>
	<button label="OK" label_selected="OK" name="OK"/>
	<button label="Cancelar" label_selected="Cancelar" name="Cancel"/>
	<check_box label="Limite de complexidade máxima do avatar (ARC)" name="RenderAvatarMaxComplexity"/>
	<check_box label="Máximo de avatares renderizados por completo (não impostores)" name="RenderAvatarMaxNonImpostors"/>
</floater>
