<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="prefs_graphics_advanced" title="Configurações gráficas avançadas">
	<text name="GeneralText">
		Geral
	</text>
	<slider label="Distância de visão:" name="DrawDistance"/>
	<text name="DrawDistanceMeterText2">
		m
	</text>
	<slider label="Máx. de partículas:" name="MaxParticleCount"/>
	<slider label="Qualidade de pós-processamento:" name="RenderPostProcess"/>
	<text name="PostProcessText">
		Baixo
	</text>
	<text name="AvatarText">
		Avatar
	</text>
	<slider label="Complexidade máxima:" name="IndirectMaxComplexity" tool_tip="Define em que ponto um avatar visualmente complexo será exibido como JellyDoll"/>
	<text name="IndirectMaxComplexityText">
		0
	</text>
	<slider label="Máx. de avatares totalmente renderizados:" name="IndirectMaxNonImpostors"/>
	<text name="IndirectMaxNonImpostorsText">
		0
	</text>
	<slider label="Detalhes:" name="AvatarMeshDetail"/>
	<text name="AvatarMeshDetailText">
		Baixo
	</text>
	<slider label="Física:" name="AvatarPhysicsDetail"/>
	<text name="AvatarPhysicsDetailText">
		Baixo
	</text>
	<text name="HardwareText">
		Hardware
	</text>
	<slider label="Cache de texturas (MB):" name="GraphicsCardTextureMemory" tool_tip="Espaço de memória disponível para texturas. Em geral, é a memória da placa de vídeo. Um valor menor pode aumentar a velocidade, mas também pode causar texturas borradas."/>
	<slider label="Proporção da distância de neblina:" name="fog"/>
	<slider label="Gama:" name="gamma"/>
	<text name="(brightness, lower is brighter)">
		(0 = brilho padrão, menor = mais claro)
	</text>
	<check_box label="Filtragem anisotrópica (mais lento quando ativado)" name="ani"/>
	<check_box initial_value="true" label="Ativar objetos de buffer de vértices OpenGL" name="vbo" tool_tip="Se você tiver hardware gráfico moderno, ativar esta opção pode melhorar o desempenho. Em hardware antigo, VBOs podem ser mal implementados, o que pode causar travamentos quando esta opção estiver ativada."/>
	<check_box initial_value="true" label="Ativar compressão de texturas (requer reinício)" name="texture compression" tool_tip="Comprime texturas na memória de vídeo para permitir carregar texturas de maior resolução (leve perda de qualidade de cor)."/>
	<check_box initial_value="true" label="Ativar suporte a telas HiDPI (requer reinício)" name="use HiDPI" tool_tip="Ativa OpenGL para renderização em alta resolução."/>
	<text name="antialiasing label">
		Antisserrilhamento:
	</text>
	<combo_box label="Antisserrilhamento" name="fsaa">
		<combo_box.item label="Desativado" name="FSAADisabled"/>
		<combo_box.item label="2x" name="2x"/>
		<combo_box.item label="4x" name="4x"/>
		<combo_box.item label="8x" name="8x"/>
		<combo_box.item label="16x" name="16x"/>
	</combo_box>
	<text name="antialiasing restart">
		(Requer reinício)
	</text>
	<text name="MeshText">
		Malha
	</text>
	<slider label="Detalhes da malha do terreno:" name="TerrainMeshDetail"/>
	<text name="TerrainMeshDetailText">
		Baixo
	</text>
	<slider label="Árvores:" name="TreeMeshDetail"/>
	<text name="TreeMeshDetailText">
		Baixo
	</text>
	<slider label="Objetos:" name="ObjectMeshDetail"/>
	<text name="ObjectMeshDetailText">
		Baixo
	</text>
	<slider label="Flexiprims:" name="FlexibleMeshDetail"/>
	<text name="FlexibleMeshDetailText">
		Baixo
	</text>
	<text name="ShadersText">
		Shader
	</text>
	<check_box initial_value="true" label="Água transparente" name="TransparentWater"/>
	<check_box initial_value="true" label="Bump mapping e brilho" name="BumpShiny"/>
	<check_box initial_value="true" label="Luzes locais" name="LocalLights"/>
	<slider label="Detalhes do terreno:" name="TerrainDetail"/>
	<text name="TerrainDetailText">
		Baixo
	</text>
	<check_box initial_value="true" label="Cálculo de pele do avatar por hardware" name="AvatarVertexProgram"/>
	<check_box initial_value="true" label="Roupas do avatar" name="AvatarCloth"/>
	<text name="ReflectionsText">
		Reflexos da água:
	</text>
	<combo_box name="Reflections">
		<combo_box.item label="Mínimo" name="0"/>
		<combo_box.item label="Terreno e árvores" name="1"/>
		<combo_box.item label="Todos os objetos estáticos" name="2"/>
		<combo_box.item label="Todos os avatares e objetos" name="3"/>
		<combo_box.item label="Tudo" name="4"/>
	</combo_box>
	<check_box initial_value="true" label="Shader atmosférico" name="WindLightUseAtmosShaders"/>
	<slider label="Céu:" name="SkyMeshDetail"/>
	<text name="SkyMeshDetailText">
		Baixo
	</text>
	<check_box initial_value="true" label="Modelo de iluminação avançado" name="UseLightShaders"/>
	<check_box initial_value="true" label="Oclusão de ambiente" name="UseSSAO"/>
	<check_box initial_value="true" label="Profundidade de campo" name="UseDoF"/>
	<text name="RenderShadowDetailText">
		Sombras:
	</text>
	<combo_box name="ShadowDetail">
		<combo_box.item label="Nenhuma" name="0"/>
		<combo_box.item label="Sol/Lua" name="1"/>
		<combo_box.item label="Sol/Lua + projetores" name="2"/>
	</combo_box>
	<button label="Redefinir para configurações recomendadas" name="Defaults"/>
	<button label="OK" label_selected="OK" name="OK"/>
	<button label="Cancelar" label_selected="Cancelar" name="Cancel"/>
	<check_box label="RenderAvatarMaxComplexity" name="RenderAvatarMaxComplexity"/>
	<check_box label="RenderAvatarMaxNonImpostors" name="RenderAvatarMaxNonImpostors"/>
</floater>
