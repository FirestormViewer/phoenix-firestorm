<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater
 name="group_titles"
 help_topic="fs_group_titles"
 title="Títulos de grupo"
 width="505"
 height="340"
 min_width="505"
 min_height="200"
 save_rect="true"
 single_instance="true"
 can_resize="true"
 can_minimize="true"
 can_close="true"
 can_drag_on_left="false">

	<floater.string name="NoGroupTitle" value="&lt;Sem título de grupo&gt;"/>
	<floater.string name="ClearAllRegions" value="Limpar todas as regiões"/>

	<filter_editor
	 follows="left|top|right"
	 height="23"
	 layout="topleft"
	 left="5"
	 label="Filtrar títulos de grupo"
	 max_length_bytes="20"
	 name="filter_input"
	 top="5"
	 right="-5" />

	<scroll_list
	 name="title_list"
	 follows="all"
	 draw_heading="true"
	 layout="topleft"
	 right="-5"
	 left="5"
	 height="255">
		<column
		 name="grouptitle"
		 sort_column="title_sort_column"
		 label="Título"/>
		<column
		 name="groupname"
		 sort_column="name_sort_column"
		 label="Grupo"/>
		<column
		 name="regionname"
		 label="Região automática"
		 width="140" />
		<column
		 name="role_id"
		 width="-1"/>
		<column
		 name="group_id"
		 width="-1"/>
		<column
		 name="title_sort_column"
		 width="-1"/>
		<column
		 name="name_sort_column"
		 width="-1"/>
	</scroll_list>

	<button
	 name="btnSetRegion"
	 label="Esta região"
	 font="SansSerifSmall"
	 tool_tip="Atribuir a região em que você está agora"
	 height="22"
	 width="80"
	 left="5"
	 follows="left|bottom"/>
	<button
	 name="btnSetRegionManual"
	 label="Digitar região"
	 font="SansSerifSmall"
	 tool_tip="Digitar manualmente o nome de uma região para atribuir"
	 height="22"
	 width="105"
	 left_pad="1"
	 top_delta="0"
	 follows="left|bottom"/>
	<button
	 name="btnClearRegion"
	 label="Limpar região"
	 font="SansSerifSmall"
	 tool_tip="Remover a atribuição de região do título selecionado"
	 height="22"
	 width="95"
	 left_pad="1"
	 top_delta="0"
	 follows="left|bottom"/>

	<button
	 name="btnInfo"
	 label="Info"
	 tool_tip="Mostrar informações sobre o grupo do título selecionado"
	 font="SansSerifSmall"
	 height="22"
	 width="75"
	 right="-131"
	 top_delta="0"
	 follows="right|bottom"/>
	<button
	 name="btnActivate"
	 label="Ativar"
	 tool_tip="Ativar o título de grupo selecionado"
	 font="SansSerifSmall"
	 height="22"
	 width="100"
	 right="-30"
	 top_delta="0"
	 follows="right|bottom"/>
	<button
	 image_overlay="Refresh_Off"
	 tool_tip="Atualizar a lista de títulos de grupo disponíveis"
	 name="btnRefresh"
	 height="22"
	 width="25"
	 right="-4"
	 top_delta="0"
	 follows="right|bottom"/>

	<check_box
	 follows="left|bottom"
	 height="16"
	 label="Definir como &quot;nenhum&quot; em regiões não atribuídas"
	 layout="topleft"
	 left="5"
	 name="none_on_unassigned" />
</floater>
