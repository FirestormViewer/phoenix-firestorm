						<stat_bar label="Física - outros" name="simsimphysicsothermsec"/>
						<stat_bar label="Tempo de espera" name="simsleepmsec"/>
						<stat_bar label="Bombear ES" name="simpumpiomsec"/>
					</stat_view>
				</stat_view>
			</stat_view>
