<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel label="Região" name="General">
	<text name="region_text_lbl">
		Região:
	</text>
	<text name="region_text">
		desconhecida
	</text>
	<text name="estate_id_lbl">
		ID da propriedade:
	</text>
	<line_editor name="estate_id" initial_value="desconhecido"/>
	<text name="version_channel_text_lbl">
		Versão:
	</text>
	<text name="version_channel_text">
		desconhecida
	</text>
	<text name="grid_position_lbl">
		Posição no grid:
	</text>
	<line_editor name="grid_position_x" default_text="n./v."/>
	<line_editor name="grid_position_y" default_text="n./v."/>
	<text name="region_type_lbl">
		Tipo:
	</text>
	<text name="region_type">
		desconhecido
	</text>
	<check_box label="Bloquear terraformação" name="block_terraform_check"/>
	<check_box label="Bloquear voo" name="block_fly_check"/>
	<check_box label="Bloquear sobrevoo de parcelas" name="block_fly_over_check" tool_tip="Estende as verificações de acesso para cima para impedir o sobrevoo de uma parcela"/>
	<check_box label="Permitir dano" name="allow_damage_check"/>
	<check_box label="Restringir empurrões" name="restrict_pushobject"/>
	<check_box label="Permitir revenda de terreno" name="allow_land_resell_check"/>
	<check_box label="Permitir redistribuição de terreno" name="allow_parcel_changes_check"/>
	<check_box label="Bloquear exibição de terreno na busca" name="block_parcel_search_check" tool_tip="Exibir esta região e suas parcelas nos resultados de busca"/>
	<spinner label="Limite de avatares" name="agent_limit_spin"/>
	<spinner label="Bônus de objetos" name="object_bonus_spin"/>
	<text label="Classificação de conteúdo" name="access_text">
		Classificação:
	</text>
	<icons_combo_box label="Moderado" name="access_combo">
		<icons_combo_box.item label="Adult" name="Adult" value="42"/>
		<icons_combo_box.item label="Moderado" name="Mature" value="21"/>
		<icons_combo_box.item label="Geral" name="PG" value="13"/>
	</icons_combo_box>
	<button label="Aplicar" name="apply_btn"/>
	<button label="Teleportar um residente para casa..." name="kick_btn"/>
	<button label="Teleportar todos os residentes para casa..." name="kick_all_btn"/>
	<button label="Enviar mensagem para a região..." name="im_btn"/>
	<button label="Gerenciar telehub..." name="manage_telehub_btn"/>
	<button label="Gerenciar agendamento de reinício..." name="manage_restart_btn"/>
</panel>
