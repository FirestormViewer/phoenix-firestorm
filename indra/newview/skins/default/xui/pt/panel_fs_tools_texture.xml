<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<panel name="Texture" label="Textura">
	<panel.string name="paste_error_face_selection_mismatch">
		Se várias faces forem copiadas, o objeto de destino deve ter o mesmo número de faces selecionadas.
	</panel.string>
	<panel.string name="paste_error_object_face_count_mismatch">
		Se todas as faces de um objeto forem copiadas, o objeto de destino deve ter o mesmo número de faces.
	</panel.string>
	<panel.string name="paste_error_inventory_not_found">
		Uma ou mais texturas não foram encontradas no inventário.
	</panel.string>
	<panel.string name="paste_options">
		Copiar parâmetros de textura para a área de transferência
	</panel.string>
	<tab_container name="tabs_material_type">
		<panel label="PBR" name="panel_material_type_pbr">
			<panel name="panel_material_maps">
				<texture_picker label="Material" name="pbr_control" tool_tip="Clique para escolher um material PBR"/>
				<texture_picker label="Cor base" name="base_color_picker" tool_tip="Clique para escolher o mapa de cor base (albedo)"/>
				<color_swatch label="Tom" name="base_color_tint_picker" tool_tip="Clique para escolher o tom da cor base"/>
				<button name="btn_select_same_gltf" tool_tip="Selecionar todas as faces com o mesmo material GLTF desta"/>
				<texture_picker label="Normal" name="normal_map_picker" tool_tip="Clique para escolher o mapa normal"/>
				<texture_picker label="Emissivo" name="emissive_map_picker" tool_tip="Clique para escolher o mapa de emissão"/>
				<color_swatch label="Tom" name="emissive_color_tint_picker" tool_tip="Clique para escolher o tom emissivo"/>
				<texture_picker label="(O)RM" name="metallic_map_picker" tool_tip="Clique para escolher o mapa de metalicidade-rugosidade, que pode conter um canal de oclusão opcional"/>
			</panel>

			<panel name="panel_material_parameters">
				<check_box label="Dupla face" name="double sided"/>
				<spinner label="Alpha" name="transparency"/>
				<text name="blend mode label">
					Modo
				</text>
				<combo_box top_delta="-3">
					<combo_box.item label="Opaco" name="None"/>
					<combo_box.item label="Mistura" name="Alpha blending"/>
					<combo_box.item label="Máscara" name="Alpha masking"/>
				</combo_box>
				<spinner label="Corte" name="alpha cutoff"/>
				<spinner label="Metalicidade" name="metalness factor"/>
				<spinner label="Rugosidade" name="roughness factor"/>
				<button name="save_selected_pbr" label="Salvar"/>
			</panel>

			<!-- BEGIN PBR Material texture transform parameters -->
			<tab_container name="tabs_pbr_transforms">
				<panel label="Todos" name="panel_pbr_transforms_all">
					<panel name="pbr_transforms_all_scale">
						<text name="pbr_transforms_all_scale_label">
							Escala
						</text>
						<text name="labelGltfTextureScaleU_All">
							U
						</text>
						<button name="flipTextureScaleMU" tool_tip="Inverter"/>
						<text name="labelGltfTextureScaleV_All">
							V
						</text>
						<button name="flipTextureScaleMV" tool_tip="Inverter"/>
					</panel>
					<panel name="pbr_transforms_all_offset">
						<text name="pbr_transforms_all_offset_label">
							Deslocamento
						</text>
						<text name="labelGltfTextureOffsetU_All">
