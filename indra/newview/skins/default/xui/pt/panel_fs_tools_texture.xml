							Rotação
						</text>
					</panel>
				</panel>
				<panel label="Normal" name="panel_blinn_phong_normal">
					<panel name="transforms_normal_scale">
						<text name="transforms_normal_scale_label">
							Escala
						</text>
						<text name="labelBumpyScaleU">
							H
						</text>
						<button name="flipTextureScaleNU" tool_tip="Inverter"/>
						<text name="labelBumpyScaleV">
							V
						</text>
						<button name="flipTextureScaleNV" tool_tip="Inverter"/>
					</panel>
					<panel name="transforms_normal_offset">
						<text name="transforms_normal_offset_label">
							Deslocamento
						</text>
						<text name="labelBumpyOffsetU">
							H
						</text>
						<text name="labelBumpyOffsetU">
							V
						</text>
					</panel>
					<panel name="transforms_normal_rotation">
						<text name="transforms_normal_rotation_label">
							Rotação
						</text>
					</panel>
				</panel>
				<panel label="Especular" name="panel_blinn_phong_specular">
					<panel name="transforms_specular_scale">
						<text name="transforms_specular_scale_label">
							Escala
						</text>
						<text name="labelShinyScaleU">
							H
						</text>
						<button name="flipTextureScaleSU" tool_tip="Inverter"/>
						<text name="labelShinyScaleV">
							V
						</text>
						<button name="flipTextureScaleSV" tool_tip="Inverter"/>
					</panel>
					<panel name="transforms_specular_offset">
						<text name="transforms_specular_offset_label">
							Deslocamento
						</text>
						<text name="labelShinyOffsetU">
							H
						</text>
						<text name="labelShinyOffsetV">
							V
						</text>
					</panel>
					<panel name="transforms_specular_rotation">
						<text name="transforms_specular_rotation_label">
							Rotação
						</text>
					</panel>
				</panel>
			</tab_container>
		</panel>
		<panel label="Mídia" name="panel_material_type_media">
			<text name="media_info">
				URL da mídia selecionada
			</text>
			<button name="add_media" tool_tip="Adicionar mídia" label="Escolher..."/>
			<button name="delete_media" tool_tip="Excluir esta textura de mídia" label="Remover"/>
			<button label="Alinhar" label_selected="Alinhar mídia" name="button align" tool_tip="Alinhar textura de mídia (precisa carregar primeiro)"/>
		</panel>
	</tab_container>
	<panel name="panel_face_params">
		<spinner label="Repetições/metro" name="rptctrl"/>
		<check_box label="Sincronizar materiais" name="checkbox_sync_settings" tool_tip="Sincronizar parâmetros de mapeamento de textura"/>
		<check_box label="Alinhar faces planares" name="checkbox planar align" tool_tip="Alinha texturas em todas as faces selecionadas com a última face selecionada. Requer mapeamento planar."/>
		<text name="tex gen">
			Mapeamento
		</text>
		<combo_box name="combobox texgen">
			<combo_box.item label="Padrão" name="Default"/>
			<combo_box.item label="Planar" name="Planar"/>
		</combo_box>
		<button name="button align textures" label="Alinhar" tool_tip="Alinhar camadas de textura atuais"/>
	</panel>
	<button name="copy_face_btn" tool_tip="Copiar parâmetros de textura para a área de transferência"/>
	<button name="paste_face_btn" tool_tip="Colar parâmetros de textura da área de transferência"/>
	<spinner label="Brilho" name="glow" label_width="50" width="115"/>
</panel>
