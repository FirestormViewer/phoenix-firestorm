<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel name="navigation_bar">
	<layout_stack name="navigation_favorites_bar_visibility_stack">
		<layout_panel name="navigation_bar_visibility_panel">
			<layout_stack name="location_search_layout">
				<layout_panel name="navigation_buttons_visibility_panel" right="253">
					<pull_button name="back_btn" tool_tip="Voltar ao local anterior"/>
					<pull_button name="forward_btn" tool_tip="Avançar um local"/>
					<button name="home_btn" tool_tip="Teleportar para minha casa[LOCATION]"/>
					<button name="About_Land" label="Terreno" tool_tip="Abrir janela de informações do terreno"/>
					<button name="PersonalLighting" label="Iluminação" tool_tip="Abre a janela de iluminação pessoal" width="90"/>
				</layout_panel>
				<layout_panel name="location_bar_visibility_panel">
					<location_input label="Local" name="location_combo"/>
				</layout_panel>
				<layout_panel name="search_bar_visibility_panel">
					<search_combo_box label="Buscar" name="search_combo_box" tool_tip="Buscar">
						<combo_editor label="Buscar no Metaverso" name="search_combo_editor"/>
					</search_combo_box>
				</layout_panel>
			</layout_stack>
		</layout_panel>
		<layout_panel name="favorites_bar_visibility_panel">
			<favorites_bar name="favorite" tool_tip="Arraste landmarks para cá para acesso rápido aos seus lugares favoritos.">
				<label name="favorites_bar_label" tool_tip="Arraste landmarks para cá para acesso rápido aos seus lugares favoritos.">
					Barra de favoritos
				</label>
				<chevron_button name="more_btn" tool_tip="Mostrar mais dos meus favoritos"/>
			</favorites_bar>
		</layout_panel>
	</layout_stack>
</panel>
