<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel label="Membros e funções" name="roles_tab">
	<panel.string name="default_needs_apply_text">
		Há alterações não salvas.
	</panel.string>
	<panel.string name="want_apply_text">
		Deseja salvar suas alterações?
	</panel.string>
	<tab_container name="roles_tab_container">
		<panel label="Membros" name="members_sub_tab" tool_tip="Membros">
			<panel.string name="help_text">
				Você pode adicionar ou remover funções atribuídas aos membros.
Segure Ctrl e clique nos nomes para
selecionar vários membros.
			</panel.string>
			<panel.string name="donation_area">
				[AREA] m².
			</panel.string>
			<filter_editor label="Filtrar membros" name="filter_input"/>
			<name_list name="member_list">
				<name_list.columns label="Membro" name="name" relative_width="0.30"/>
				<name_list.columns label="Contribuição" name="donated" relative_width="0.33"/>
				<name_list.columns label="Status" name="online"/>
				<name_list.columns label="Título" name="title"/>
			</name_list>
			<button label="Convidar" name="member_invite"/>
			<button label="Expulsar" name="member_eject"/>
			<button label="Banir" name="member_ban"/>
			<button label="Exportar lista" name="export_list"/>
		</panel>
		<panel label="Funções" name="roles_sub_tab" tool_tip="Funções">
			<panel.string name="help_text">
				Funções têm um título e uma lista de habilidades
permitidas. Membros podem pertencer a
várias funções. Um grupo pode ter até 10 funções,
incluindo &apos;Todos&apos; e &apos;Proprietários&apos;.
			</panel.string>
			<panel.string name="cant_delete_role">
				As funções &quot;Todos&quot; e &quot;Proprietários&quot; são especiais e não podem ser excluídas.
			</panel.string>
			<panel.string name="power_folder_icon">
				Inv_FolderClosed
			</panel.string>
			<panel.string name="power_all_have_icon">
				Checkbox_On
			</panel.string>
			<panel.string name="power_partial_icon">
				Checkbox_Off
			</panel.string>
			<filter_editor label="Filtrar funções" name="filter_input"/>
			<name_list name="role_list">
				<name_list.columns label="Função" name="name"/>
				<name_list.columns label="Título" name="title"/>
				<name_list.columns label="#" name="members"/>
			</name_list>
			<button label="Nova função" name="role_create"/>
			<button label="Copiar função" name="role_copy"/>
			<button label="Excluir função" name="role_delete"/>
		</panel>
		<panel label="Habilidades" name="actions_sub_tab" tool_tip="Veja a descrição de uma habilidade e quais funções e membros podem executá-la.">
			<panel.string name="help_text">
				Habilidades permitem que membros em funções façam coisas
específicas no grupo. Há uma grande variedade de habilidades.
			</panel.string>
			<filter_editor label="Filtrar habilidades" name="filter_input"/>
			<scroll_list name="action_list" tool_tip="Selecione uma habilidade para ver mais detalhes.">
				<scroll_list.columns label="" name="action"/>
			</scroll_list>
		</panel>
		<panel label="Residentes banidos" name="banlist_sub_tab" tool_tip="Ver residentes banidos deste grupo.">
			<panel.string name="help_text">
				Qualquer residente na lista de banimento não poderá entrar no grupo.
			</panel.string>
			<panel.string name="ban_count_template">
				Banimentos: [COUNT]/[LIMIT]
			</panel.string>
			<filter_editor label="Filtrar lista de banimento" name="filter_input"/>
			<name_list name="ban_list">
				<name_list.columns label="Residente" name="name"/>
				<name_list.columns label="Data do banimento" name="ban_date"/>
			</name_list>
			<button label="Banir" name="ban_create" tool_tip="Banir residentes do grupo"/>
			<button label="Remover banimento" name="ban_delete" tool_tip="Remover banimento dos residentes selecionados"/>
			<button name="ban_refresh" tool_tip="Atualizar lista de banimento"/>
			<text name="ban_count" width="150"></text>
		</panel>
	</tab_container>
	<panel name="members_footer">
		<text name="assigned_roles_label">
			Funções atribuídas
        </text>	
		<scroll_list name="member_assigned_roles">
			<scroll_list.columns label="" name="checkbox"/>
			<scroll_list.columns label="" name="role"/>
		</scroll_list>
		<text name="static2">
			Habilidades permitidas
		</text>
		<scroll_list name="member_allowed_actions" tool_tip="Para detalhes de cada habilidade permitida, veja a aba Habilidades.">
			<scroll_list.columns label="" name="action"/>
		</scroll_list>
	</panel>
	<panel name="roles_footer">
		<text name="role_name_label">
			Função:
		</text>
		<line_editor name="role_name"/>
		<text name="role_title_label">
			Título da função
		</text>
		<line_editor name="role_title"/>
		<text name="description_label">
			Descrição
		</text>
		<text_editor name="role_description"/>
		<check_box label="Mostrar membros" name="role_visible_in_list" tool_tip="Define se membros desta função são visíveis na aba Geral para pessoas fora do grupo."/>
		
		<panel name="group_roles_layout_panel">
			<text name="assigned_members_label">
				Membros na função
			</text>
		</panel>
		<panel name="group_roles_layout_panel2">
			<text name="allowed_abilities_label" tool_tip="Lista de habilidades da função selecionada.">
				Habilidades permitidas
			</text>
			<scroll_list name="role_allowed_actions" tool_tip="Para detalhes de cada habilidade permitida, veja a aba Habilidades.">
				<scroll_list.columns label="" name="checkbox"/>
				<scroll_list.columns label="" name="action"/>
			</scroll_list>
		</panel>
	</panel>
	<panel name="actions_footer">
		<panel name="action_description_panel">
			<text_editor name="action_description">
				Esta habilidade é &apos;Expulsar membros deste grupo&apos;. Apenas um proprietário pode expulsar outro proprietário.
			</text_editor>
		</panel>
		<text name="action_roles_label">
			Funções com esta habilidade
		</text>
		<text name="action_members_label">
			Membros com esta habilidade
		</text>
	</panel>
</panel>
