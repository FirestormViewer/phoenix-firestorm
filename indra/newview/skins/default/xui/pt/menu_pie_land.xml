<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<pie_menu
    name="Land Pie">
    <pie_slice
        label="Sobre o Terreno..."
        name="Place Information...">
        <pie_slice.on_click
            function="Floater.Show"
            parameter="about_land" />
    </pie_slice>
    <pie_slice
        enabled="false"
        label="Criar"
        name="Create">
        <pie_slice.on_click
            function="Land.Build" />
        <pie_slice.on_enable
            function="EnableEdit" />
    </pie_slice>
    <pie_slice
        label="Ir Aqui"
        name="Go Here">
        <pie_slice.on_click
            function="GoToObject" />
    </pie_slice>
    <pie_slice
        label="Sentar Aqui"
        name="Sit Here">
        <pie_slice.on_click
            function="Land.Sit" />
    </pie_slice>
    <pie_slice
        enabled="false"
        label="Silenc. Dono Part."
        name="Mute Particle">
        <pie_slice.on_click
            function="Particle.Mute" />
        <pie_slice.on_enable
            function="EnableMuteParticle" />
    </pie_slice>
    <pie_slice
        enabled="false"
        label="Comprar Passagem"
        name="Land Buy Pass Pie">
        <pie_slice.on_click
            function="Land.BuyPass" />
        <pie_slice.on_enable
            function="Land.EnableBuyPass" />
    </pie_slice>
    <pie_slice
        enabled="false"
        label="Editar Terreno"
        name="Edit Terrain">
        <pie_slice.on_click
            function="Land.Edit" />
        <pie_slice.on_enable
            function="EnableEdit" />
    </pie_slice>
    <pie_slice
        enabled="false"
        label="Comprar Este Terreno"
        name="Land Buy Pie">
        <pie_slice.on_click
            function="Land.Buy" />
        <pie_slice.on_enable
            function="World.EnableBuyLand" />
    </pie_slice>
</pie_menu>