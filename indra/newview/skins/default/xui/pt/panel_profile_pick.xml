<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel name="panel_pick_info">
	<panel.string name="location_notice">
		(será atualizado após salvar)
	</panel.string>
	<layout_stack name="main_pick_stack">
		<layout_panel name="main_pick_lp">
			<text name="title_label">
				Título:
			</text>
			<text name="description_label">
				Descrição:
			</text>
			<button name="btn_preview" tool_tip="Alternar pré-visualização da descrição da seleção"/>
			<text name="location_label">
				Localização:
			</text>
			<line_editor name="pick_location">
				Carregando...
			</line_editor>
		</layout_panel>
		<layout_panel name="util_buttons_lp">
			<layout_stack name="util_buttons_stack">
				<layout_panel name="map_btn_lp">
					<button label="Mostrar no mapa" name="show_on_map_btn"/>
				</layout_panel>
				<layout_panel name="tp_btn_lp">
					<button label="Teleportar" name="teleport_btn"/>
				</layout_panel>
				<layout_panel name="set_to_curr_location_btn_lp">
					<button label="Definir local" name="set_to_curr_location_btn" tool_tip="Usar localização atual"/>
				</layout_panel>
			</layout_stack>
		</layout_panel>
		<layout_panel name="save_changes_lp">
			<layout_stack name="save_changes_stack">
				<layout_panel name="create_btn_lp">
					<button name="create_changes_btn" label="Criar seleção"/>
				</layout_panel>
				<layout_panel name="save_btn_lp">
					<button name="save_changes_btn" label="Salvar seleção"/>
				</layout_panel>
				<layout_panel name="cancel_btn_lp">
					<button name="cancel_changes_btn" label="Cancelar"/>
				</layout_panel>
			</layout_stack>
		</layout_panel>
	</layout_stack>
</panel>
