<!-- The layout is a vertical stack of 3 rows, and each row a horizontal stack of panels -->
	<layout_stack name="poser_stack">
		<layout_panel name="regular_controls_layout">
			<panel name="joints_parent_panel">
				<tab_container name="joints_tabs">
					<panel title="Mov." name="positionRotation_panel">
						<panel name="move_tab_panel">
							<text name="av_position_updown_label">
								Cima/Baixo:
							</text>
							<slider name="av_position_updown" tool_tip="Move o avatar selecionado para cima ou para baixo"/>
							<text name="av_position_leftright_label">
								Esq./Dir.:
							</text>
							<slider name="av_position_leftright" tool_tip="Move o avatar selecionado para a esquerda ou direita"/>
							<text name="av_position_inout_label">
								Para dentro/fora:
							</text>
							<slider name="av_position_inout" tool_tip="Move o avatar selecionado para dentro ou para fora"/>
							<check_box name="unlock_pelvis_for_bvh_save_checkbox" label="Desbloquear pelve em BVH" tool_tip="Se esta pose for salva como BVH, a pelve não será &apos;travada&apos;. Isso permite que outras animações in-world movam o avatar inteiro. Use esta opção quando a pose for reproduzida &apos;por cima&apos; de outras animações." />
							<!-- so this panel behaves like the others in the code behind, it has an invisible list... -->
							<scroll_list name="entireAv_joint_scroll">
								<scroll_list.columns label="Parte do corpo" name="joint"/>
							</scroll_list>
						</panel>
					</panel>
					<panel title="Corpo" name="body_joints_panel">
						<scroll_list name="body_joints_scroll">
							<scroll_list.columns label="Parte do corpo" name="joint"/>
						</scroll_list>
					</panel>
					<panel title="Rosto" name="face_joints_panel">
						<scroll_list name="face_joints_scroll">
							<scroll_list.columns label="Parte do corpo" name="joint"/>
						</scroll_list>
					</panel>
					<tab_container title="Mãos" name="hands_tabs">
						<panel title="Ajustar" name="hands_joints_panel">
							<scroll_list name="hand_joints_scroll">
								<scroll_list.columns label="Parte do corpo" name="joint"/>
							</scroll_list>
						</panel>
						<panel title="Predefinidos" name="hands_presets_panel">
							<scroll_list name="hand_presets_scroll">
								<scroll_list.columns label="Nome predefinido" name="name"/>
							</scroll_list>
							<button label="Aplicar esquerda" name="button_loadHandPoseLeft" tool_tip="Clique para aplicar o predefinido selecionado na mão esquerda"/>
							<button label="Aplicar direita" name="button_loadHandPoseRight" tool_tip="Clique para aplicar o predefinido selecionado na mão direita"/>
						</panel>
					</tab_container>
					<panel title="Outros" name="misc_joints_panel">
						<scroll_list name="misc_joints_scroll">
							<scroll_list.columns label="Parte do corpo" name="joint"/>
						</scroll_list>
					</panel>
					<panel title="Física" name="collision_volumes_panel">
						<scroll_list name="collision_volumes_scroll">
							<scroll_list.columns label="Física" name="joint"/>
						</scroll_list>
					</panel>
					<panel title="Modelo" name="avatarSelection_panel">
						<scroll_list tool_tip="Selecione avatar ou Animesh para animar." name="avatarSelection_scroll">
							<scroll_list.columns label="Seleção..." name="name"/>
						</scroll_list>
						<button name="refresh_avatars" tool_tip="Atualizar lista de avatares e Animesh"/>
						<button label="Iniciar pose" label_selected="Parar pose" tool_tip="Iniciar pose no avatar ou Animesh selecionado, se permitido." name="start_stop_posing_button"/>
						<button label="Aplicar T-pose" tool_tip="Clique para colocar o avatar selecionado em T-pose" name="set_t_pose_button"/>
					</panel>
					<panel title="Config." name="settings_panel">
						<text name="trackpad_sensitivity_label">
							Sensibil. da esfera de controle:
						</text>
						<slider name="trackpad_sensitivity_slider" tool_tip="Define a sensibilidade da esfera de controle"/>
						<check_box name="stop_posing_on_close_checkbox" label="Parar ao fechar" tool_tip="Não parar a pose ao fechar pode ajudar a não perder o trabalho já feito."/>
						<check_box name="also_save_bvh_checkbox" label="Criar BVH ao salvar" tool_tip="Ao salvar a pose, um arquivo BVH também será criado. Arquivos BVH podem ser enviados em Construir &gt; Upload &gt; Animação e usados para posar seu avatar ou outros avatares. Para isso, a base das juntas deve ser zerada, pois o BVH não é derivado de outras poses."/>
						<check_box name="confirm_overwrite_on_save_checkbox" label="Confirmar sobrescrita" tool_tip="Se a pose for salva com um nome já existente, o botão Salvar deve ser clicado novamente para confirmar a sobrescrita."/>
						<check_box name="natural_direction_checkbox" label="Usar direção natural" tool_tip="O esqueleto usa rotações de juntas pouco naturais por padrão, o que dificulta a pose. Quando ativado, as juntas usam rotações mais naturais."/>
						<check_box name="show_joint_markers_checkbox" label="Mostrar marcadores de juntas" tool_tip="Mostra indicadores para facilitar a seleção de juntas durante a pose."/>
						<check_box name="dof_edit_mode_checkbox" label="Prof. de campo no modo ediç." tool_tip="Ao usar o manipulador, a profundidade de campo normalmente fica desativada. Com esta opção, ela permanece ativa ao editar poses ou prims."/>
					</panel>
				</tab_container>
				<button name="toggleVisualManipulators" tool_tip="Ativar/desativar manipuladores visuais" />
			</panel>
			<panel name="joint_manipulation_panel">
				<tab_container name="modifier_tabs">
					<panel label="Rotação" name="trackball_panel">
						<fs_virtual_trackpad name="limb_rotation" tool_tip="Altera a rotação das partes do corpo selecionadas no momento. Segure CTRL para mudanças lentas. Use a roda do mouse para ajustar o 3º eixo. Use Shift ou Alt para alternar entre eixos."/>
						<text name="limb_pitch_label">
							Cima/Baixo:
						</text>
						<text name="limb_yaw_label">
							Esq./Dir.:
						</text>
						<text name="limb_roll_label">
							Rolar:
						</text>
					</panel>
					<panel title="Pos. / Esc." name="position_panel">
						<text name="pos_x_label">
							Posição X:
						</text>
						<text name="pos_y_label">
							Posição Y:
						</text>
						<text name="pos_z_label">
							Posição Z:
						</text>
						<text name="scale_x_label">
							Escala X:
						</text>
						<text name="scale_y_label">
							Escala Y:
						</text>
						<text name="scale_z_label">
							Escala Z:
						</text>
					</panel>
				</tab_container>
				<panel name="trackball_button_panel">
					<button name="undo_change" tool_tip="Desfazer última alteração"/>
					<button name="button_redo_change" tool_tip="Refazer última alteração de rotação"/>
					<button name="poser_joint_reset" tool_tip="Clique para restaurar todas as partes selecionadas aos valores originais."/>
					<button name="delta_mode_toggle" tool_tip="Ao editar várias juntas, aplicar o mesmo delta em vez de forçar a mesma rotação. Também ajuda a evitar gimbal lock."/>
					<button name="toggle_LockWorldRotation" tool_tip="Bloquear rotação no mundo para os membros selecionados. Membros bloqueados mantêm a rotação quando os membros-pai se movem. Exemplo: com os olhos bloqueados, ao girar a cabeça os olhos continuam olhando quase na mesma direção."/>
					<button label="Esp." name="button_toggleMirrorRotation" tool_tip="Espelhar mudanças na junta oposta."/>
					<button label="Sim." name="button_toggleSympatheticRotation" tool_tip="Ajustar a junta oposta proporcionalmente."/>
					<button label="W" name="poser_world_frame_toggle" tool_tip="Aplicar rotação relativa ao mundo"/>
					<button label="A" name="poser_avatar_frame_toggle" tool_tip="Aplicar rotação relativa ao avatar"/>
					<button label="B" name="poser_screen_frame_toggle" tool_tip="Aplicar rotação relativa à tela"/>
					<button label="Copiar E &gt; D" name="button_symmetrize_left_to_right" tool_tip="Clique para copiar mudanças do lado esquerdo para o direito." />
					<button label="Copiar D &gt; E" name="button_symmetrize_right_to_left" tool_tip="Clique para copiar mudanças do lado direito para o esquerdo." />
				</panel>
			</panel>
			<panel name="poses_loadSave">
				<scroll_list tool_tip="Carregar pose para o avatar selecionado." name="poses_scroll">
					<scroll_list.columns label="Nome" name="load_file_name_column"/>
					<scroll_list.columns label="Data" name="load_file_date_column"/>
				</scroll_list>
				<line_editor label="Digite um nome para salvar a pose..." name="pose_save_name"/>
			</panel>
		</layout_panel>
		<layout_panel name="button_controls_layout">
			<panel name="button_controls_panel">
				<button name="FlipPose_avatar" tool_tip="Espelhar pose completa esquerda/direita"/>
				<button name="FlipJoint_avatar" tool_tip="Espelhar partes selecionadas esquerda/direita"/>
				<button label="Recap." name="button_RecaptureParts" tool_tip="Se as partes selecionadas não estiverem sendo posadas, captura os valores da pose atual."/>
				<button label="Partes on/off" name="toggle_PosingSelectedBones" tool_tip="Ativa ou desativa o Poser para as partes selecionadas. Quando desativado, elas são animadas normalmente (ex.: AO, poseball etc.)."/>
				<button label="Minhas poses" name="toggleLoadSavePanel" tool_tip="Carregar, salvar e gerenciar suas poses criadas"/>
				<button tool_tip="Gerenciar pasta de poses" name="open_poseDir_button"/>
				<menu_button label="Carregar pose" tool_tip="Carrega a pose atualmente selecionada." name="load_poses_button"/>
				<button label="Salvar dif." tool_tip="Salva a diferença em relação a uma pose existente. Comece de uma T-pose para iniciar um novo trabalho." name="save_poses_button"/>
			</panel>
		</layout_panel>
	</layout_stack>
</floater>
