<?xml version="1.0" encoding="utf-8"?>
<panel name="panel_login">
	<panel.string name="forgot_password_url">
		http://secondlife.com/account/request.php?lang=pt-BR
	</panel.string>
	<panel.string name="sign_up_url">
		https://www.firestormviewer.org/join-secondlife/
	</panel.string>
	<layout_stack name="ui_stack">
		<layout_panel name="ui_container">
			<combo_box label="Nome de usuário" name="username_combo" tool_tip="O nome de usuário que você escolheu ao se registrar, como zecazc12 ou Magia Solar"/>
			<line_editor label="Senha" name="password_edit"/>
			<combo_box label="Meus locais favoritos" name="start_location_combo">
				<combo_box.item label="Última posição" name="MyLastLocation"/>
				<combo_box.item label="Minha casa" name="MyHome"/>
			</combo_box>
			<button label="Entrar" name="connect_btn"/>
			<text name="sign_up_text">
				Cadastre-se
			</text>
			<check_box label="Lembrar-me" name="remember_name" tool_tip="Usuários lembrados podem ser esquecidos em Eu &gt; Preferências &gt; Avançado &gt; Nomes de usuário lembrados."/>
			<check_box label="Lembrar senha" name="remember_password"/>
			<combo_box label="Selecionar grid" name="server_combo"/>
			<text name="forgot_password_text">
				Senha esquecida
			</text>
		</layout_panel>
	</layout_stack>
</panel>
