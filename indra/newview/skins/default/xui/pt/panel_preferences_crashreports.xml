<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel border="true" follows="all" height="480" layout="topleft" left="1" top="1" width="540" label="Relatórios de falhas" name="crash_reports">
  <panel.string name="PrivacyPolicyUrl">
        https://www.firestormviewer.org/privacy-policy
    </panel.string>
  <check_box layout="topleft" follows="top|left" left="30" top="30" width="250" height="16" label="Envie relatórios de falhas para firestormviewer.org" name="checkSendCrashReports" enabled="false" />
  <check_box layout="topleft" follows="top|left" left="60" top_pad="7" height="16" label="Sempre pergunte antes de enviar" name="checkSendCrashReportsAlwaysAsk" width="250" enabled="false" />
  <check_box layout="topleft" follows="top|left" top_pad="5" height="16" label="Incluir arquivos de configurações" name="checkSendSettings" width="130" enabled="false" />
  <text name="textSendSettings" follows="left|top" layout="topleft" top_pad="5" left_delta="20" height="20" width="230" text_color="White_25">
        (contém nome de usuário)
    </text>
  <check_box layout="topleft" follows="top|left" left="60" top_pad="0" height="16" label="Incluir nome de usuário" name="checkSendName" width="160" enabled="false" />
  <text name="textSendName" follows="left|top" layout="topleft" top_pad="5" left_delta="20" height="20" width="275" text_color="White_25">
        (usado para solicitar informações adicionais, se necessário)
    </text>
  <text layout="topleft" follows="top|left" left="30" type="string" length="1" height="10" mouse_opaque="false" name="textRestartRequired" top_pad="10" visible="false" width="475">
        As alterações em qualquer configuração só terão efeito após reiniciar.
    </text>
  <text layout="topleft" follows="top|left" left="30" type="string" length="1" height="10" mouse_opaque="false" name="textInformation1" top_pad="20" width="475">
        Se as opções acima não estiverem marcadas, os relatórios de falha contêm apenas informações relacionadas à queda.
    </text>
  <text layout="topleft" follows="top|left" left="30" type="string" length="1" height="10" mouse_opaque="false" name="textInformation2" width="475">
        Os registros não são enviados; revise o conteúdo e envie por e-mail separadamente
    </text>
  <text layout="topleft" follows="top|left" left="30" type="string" length="1" height="10" mouse_opaque="false" name="textInformation3" width="475">
        se achar que podem conter informações adicionais.
    </text>
  <text layout="topleft" follows="top|left" left="30" type="string" length="1" height="10" mouse_opaque="false" name="textInformation4" top_pad="20" width="500" font.style="BOLD">
        Política de privacidade: [URL]
    </text>
</panel>
