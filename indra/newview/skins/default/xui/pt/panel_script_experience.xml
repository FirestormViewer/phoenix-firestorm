<?xml version="1.0" encoding="utf-8"?>
<panel name="script_experience" title="EXPERIÊNCIA">
	<button label="Experiência" name="Expand Experience"/>
	<check_box label="Usa experiência" name="enable_xp"/>
	<layout_stack name="xp_details">
		<layout_panel name="xp_layout_panel">
			<text name="lbl_script">
				Script:
			</text>
			<text name="lbl_associated">
				Associado a:
			</text>
			<text name="lbl_contribute">
				Você pode contribuir:
			</text>
			<text name="lbl_associate">
				Associar a:
			</text>
		</layout_panel>
		<layout_panel name="xp_choose_panel">
			<combo_box label="Escolher experiência..." name="Experiences..."/>
		</layout_panel>
	</layout_stack>
	<text name="No Experiences">
		Você não contribui para nenhuma experiência.
	</text>
</panel>
