<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<floater name="particle_editor_floater" title="Editor de partículas">
	<panel name="particle_editor_panel">
		<panel name="top_left_panel">
			<text name="Pattern_Label">
				Padrão:
			</text>

			<combo_box name="pattern_type_combo">
				<combo_box.item label="Explode" name="explode"/>
				<combo_box.item label="Angle" name="angle"/>
				<combo_box.item label="Angle Cone" name="angle_cone"/>
				<combo_box.item label="Angle Cone Empty" name="angle_cone_empty"/>
				<combo_box.item label="Drop" name="drop"/>
			</combo_box>

			<text name="Texture_Label">
				Textura:
			</text>
			<text name="Burst_Rate_Label">
				Taxa de explosão:
			</text>
			<text name="Burst_Count_Label">
				Quantidade de explosão:
			</text>
			<text name="Burst_Radius_Label">
				Raio de explosão:
			</text>
			<text name="Angle_Begin_Label">
				Ângulo inicial:
			</text>
			<text name="Burst_Speed_Min_Label">
				Vel. mín. explosão:
			</text>
			<text name="Angle_End_Label">
				Ângulo final:
			</text>
			<text name="Burst_Speed_Max_Label">
				Vel. máx. explosão:
			</text>
			<text name="Source_Max_Age_Label">
				Idade máx. - fonte:
			</text>
			<text name="Start_Alpha_Label">
				Alpha inicial:
			</text>
			<text name="Particles_Max_Age_Label">
				Idade máx. - part.:
			</text>
			<text name="End_Alpha_Label">
				Alpha final:
			</text>
			<text name="Scale_Start_Label">
				Escala inicial:
			</text>
			<text name="End_Label" left_pad="5" width="32">
				Fim:
			</text>
		</panel>

		<panel name="top_right_panel">
			<check_box name="bounce_checkbox" label="Ricochete"/>
			<check_box name="emissive_checkbox" label="Emissivo"/>
			<check_box name="follow_source_checkbox" label="Seguir fonte"/>
			<check_box name="follow_velocity_checkbox" label="Seguir velocidade"/>
			<check_box name="interpolate_color_checkbox" label="Interpolar cor"/>
			<check_box name="interpolate_scale_checkbox" label="Interpolar escala"/>
			<check_box name="target_position_checkbox" label="Posição como alvo"/>
			<check_box name="target_linear_checkbox" label="Alvo linear"/>
			<check_box name="wind_checkbox" label="Vento"/>
			<button name="copy_button" label="Copiar" tool_tip="Copia os parâmetros do sistema de partículas como script LSL para a área de transferência."/>
			<button name="inject_button" label="Injetar" tool_tip="Injeta este sistema de partículas no objeto selecionado."/>
		</panel>

		<panel name="bottom_left_panel">
			<text name="Target_Key_Label">
				UUID alvo:
			</text>

			<button name="clear_target_button" tool_tip="Remove o objeto ou avatar como alvo."/>
			<button name="pick_target_button" tool_tip="Clique para definir o objeto ou avatar como alvo."/>

			<text name="Acceleration_Label">
				Aceleração:
			</text>
			<text name="Omega_Label">
				Omega:
			</text>
		</panel>

		<panel name="bottom_right_panel">
			<color_swatch label="Cor inicial" name="start_color_selector"/>
			<color_swatch label="Cor final" name="end_color_selector"/>
		</panel>
	</panel>
</floater>
