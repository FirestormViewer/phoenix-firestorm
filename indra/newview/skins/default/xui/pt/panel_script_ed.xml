<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel name="script panel">
	<panel.string name="loading">
		Carregando...
	</panel.string>
	<panel.string name="can_not_view">
		Este script não pode ser exibido nem editado porque possui permissões restritas. Para exibir ou editar um script dentro de um objeto, você precisa de permissão total.
	</panel.string>
	<panel.string name="public_objects_can_not_run">
		Objetos públicos não podem executar scripts
	</panel.string>
	<panel.string name="script_running">
		Em execução
	</panel.string>
	<panel.string name="Title">
		Script: [NAME]
	</panel.string>
	<menu_bar name="script_menu">
		<menu label="Arquivo" name="File">
			<menu_item_call label="Salvar" name="Save"/>
			<menu_item_call label="Reverter todas as alterações" name="Revert All Changes"/>
			<menu_item_call label="Carregar de arquivo..." name="LoadFromFile"/>
			<menu_item_call label="Salvar em arquivo..." name="SaveToFile"/>
			<menu_item_call label="Preferências do editor de script" name="ScriptPrefs"/>
		</menu>
		<menu label="Editar" name="Edit">
			<menu_item_call label="Desfazer" name="Undo"/>
			<menu_item_call label="Refazer" name="Redo"/>
			<menu_item_call label="Recortar" name="Cut"/>
			<menu_item_call label="Copiar" name="Copy"/>
			<menu_item_call label="Colar" name="Paste"/>
			<menu_item_call label="Selecionar tudo" name="Select All"/>
			<menu_item_call label="Desmarcar seleção" name="Deselect"/>
			<menu_item_call label="Localizar / Substituir..." name="Search / Replace..."/>
			<menu_item_call label="Ir para a linha..." name="Go to line..."/>
		</menu>
		<menu label="Ajuda" name="Help">
			<menu_item_call label="Ajuda..." name="Help..."/>
			<menu_item_call label="Ajuda de palavras-chave" name="Keyword Help..."/>
			<menu_item_call label="Biblioteca de scripts" name="Script Library"/>
		</menu>
	</menu_bar>
	<layout_stack name="script_editor_button_bar">
		<layout_panel name="script_editor_buttons_panel">
			<button tool_tip="Salvar script" name="save_btn"/>
			<button tool_tip="Editor externo de script" name="Edit_btn"/>
			<button tool_tip="Carregar script do disco" name="load_disk_btn"/>
			<button tool_tip="Salvar script no disco" name="save_disk_btn"/>
			<button tool_tip="Recortar" name="cut_btn"/>
			<button tool_tip="Copiar" name="copy_btn"/>
			<button tool_tip="Colar" name="paste_btn"/>
			<button tool_tip="Desfazer" name="undo_btn"/>
			<button tool_tip="Refazer" name="redo_btn"/>
			<button tool_tip="Localizar / Substituir" name="search_btn"/>
			<button tool_tip="Preferências do editor de script" name="prefs_btn"/>
		</layout_panel>
	</layout_stack>
	<script_editor name="Script Editor">
		Carregando...
	</script_editor>
	<combo_box label="Inserir..." name="Insert..."/>
	<button label="Editar..." name="edit_btn_2"/>
	<button label="Salvar" name="save_btn_2"/>
</panel>
