<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="MemLeak" title="Simular vazamento de memória">
	<spinner label="Velocidade de vazamento (bytes por quadro):" name="leak_speed" label_width="224"/>
	<spinner label="Memória máx. vazada (MB):" name="max_leak" label_width="224"/>
	<text name="total_leaked_label">
		Memória vazada atual: [SIZE] KB
	</text>
	<text name="note_label_1">
		[NOTE1]
	</text>
	<text name="note_label_2">
		[NOTE2]
	</text>
	<button label="Iniciar" name="start_btn"/>
	<button label="Parar" name="stop_btn"/>
	<button label="Liberar" name="release_btn"/>
	<button label="Fechar" name="close_btn"/>
</floater>
