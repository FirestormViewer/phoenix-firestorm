<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel name="panel_snapshot_inventory">
	<text name="title">
		Inventário
	</text>
	<combo_box label="Resolução" name="texture_size_combo">
		<combo_box.item label="Pequena (128x128)" name="Small(128x128)"/>
		<combo_box.item label="Média (256x256)" name="Medium(256x256)"/>
		<combo_box.item label="Grande (512x512)" name="Large(512x512)"/>
		<combo_box.item label="Muito grande (1024x1024)" name="Very Large(1024x1024)"/>
		<combo_box.item label="Enorme (2048x2048)" name="Huge(2048x2048)"/>
		<combo_box.item label="Janela atual" name="CurrentWindow"/>
		<combo_box.item label="Personalizado" name="Custom"/>
	</combo_box>
	<spinner label="Largura x Altura" name="inventory_snapshot_width"/>
	<spinner label="" name="inventory_snapshot_height"/>
	<check_box label="Manter proporções" name="inventory_keep_aspect_check"/>
	<text name="hint_lbl">
		Para salvar a imagem como textura, selecione um dos formatos quadrados.

Custo de upload: L$ [UPLOAD_COST]
	</text>
	<button label="&#x25B6; Seleção" name="cancel_btn"/>
	<button label="Salvar" name="save_btn"/>
</panel>
