	</text>
	<text name="ReflectionsText">
		Reflexos da água:
	</text>
	<combo_box name="Reflections">
		<combo_box.item label="Nenhum (opaco)" name="-2" />
		<combo_box.item label="Nenhum (transparente)" name="-1" />
