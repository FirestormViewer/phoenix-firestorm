	</floater.string>
	<floater.string name="navmesh_simulator_status_pending_and_building">
		Algumas regiões da navmesh possuem alterações pendentes e outras estão sendo geradas.
	</floater.string>
	<floater.string name="navmesh_simulator_status_complete">
		A navmesh está atualizada.
	</floater.string>
	<floater.string name="pathing_library_not_implemented">
		Implementação da biblioteca de pathfinding não encontrada.
	</floater.string>
