<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater
 height="130"
 width="300"
 layout="topleft"
 name="floater_new_feature_notification"
 title="NOVO RECURSO"
 show_title="false"
 header_height="0"
 bg_opaque_image="Window_NoTitle_Foreground"
 bg_alpha_image="Window_NoTitle_Background"
 can_resize="false"
 can_drag_on_left="false"
 can_minimize="false"
 can_close="false">
