<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<panel
  bevel_style="none"
  border_style="line"
  follows="left|top|right|bottom"
 height="522"
  layout="topleft"
  left="0"
  name="script panel"
  width="497">
  <panel.string
    name="loading">
    Carregando...
  </panel.string>
  <panel.string
    name="can_not_view">
    Não é possível ver nem editar este script: ele está com permissões restritas. É necessário ter permissões completas para ver ou editar um script dentro de um objeto.
  </panel.string>
  <panel.string
    name="public_objects_can_not_run">
    Objetos públicos não podem executar scripts
  </panel.string>
  <panel.string
    name="script_running">
    Em execução
  </panel.string>
  <panel.string
    name="Title">
    Script atual: [NAME]
  </panel.string>
  <menu_bar
    bg_visible="false"
    follows="left|top"
    height="18"
    layout="topleft"
    left="0"
    mouse_opaque="false"
    name="script_menu"
    width="476">
    <menu
      top="0"
      height="62"
      label="Arquivo"
      layout="topleft"
      left="0"
      mouse_opaque="false"
      name="File"
      width="138">
      <menu_item_call
        label="Salvar"
        layout="topleft"
        name="Save" />
      <menu_item_separator
        layout="topleft" />
      <menu_item_call
        label="Descartar todas as alterações"
        layout="topleft"
        name="Revert All Changes" />
      <menu_item_separator
        layout="topleft" />
      <menu_item_call
        label="Carregar do arquivo..."
        layout="topleft"
        name="LoadFromFile" />
      <menu_item_call
        label="Salvar no arquivo..."
        layout="topleft"
        name="SaveToFile" />
          <menu_item_call
           label="Preferências do editor de scripts..."
           layout="topleft"
           name="ScriptPrefs" />
    </menu>
    <menu
      top="0"
      height="198"
      label="Editar"
      layout="topleft"
      mouse_opaque="false"
      name="Edit"
      width="139">
      <menu_item_call
        enabled="false"
        label="Desfazer"
        layout="topleft"
        name="Undo" />
      <menu_item_call
        enabled="false"
        label="Refazer"
        layout="topleft"
        name="Redo" />
      <menu_item_separator
        layout="topleft" />
      <menu_item_call
        enabled="false"
        label="Recortar"
        layout="topleft"
        name="Cut" />
      <menu_item_call
        enabled="false"
        label="Copiar"
        layout="topleft"
        name="Copy" />
      <menu_item_call
        enabled="false"
        label="Colar"
        layout="topleft"
        name="Paste" />
      <menu_item_separator
        layout="topleft"
        name="separator2" />
      <menu_item_call
        label="Selecionar tudo"
        layout="topleft"
        name="Select All" />
      <menu_item_call
        enabled="false"
        label="Desmarcar seleção"
        layout="topleft"
        name="Deselect" />
      <menu_item_separator
        layout="topleft"
        name="separator3" />
      <menu_item_call
        label="Localizar / Substituir..."
        layout="topleft"
        name="Search / Replace..." />
            <menu_item_call
             label="Ir para a linha..."
             layout="topleft"
             name="Go to line..." />
    </menu>
    <menu
      top="0"
      height="34"
      label="Ajuda"
      layout="topleft"
      mouse_opaque="false"
      name="Help"
      width="112">
      <menu_item_call
        label="Ajuda..."
        layout="topleft"
        name="Help..." />
      <menu_item_call
        label="Ajuda de palavras-chave..."
        layout="topleft"
        name="Keyword Help..." />
            <menu_item_call
             label="Biblioteca de scripts..."
             name="Script Library">
             <menu_item_call.on_click
              function="PromptShowURL"
              name="script_library_url"
              parameter="WebLaunchExternalTarget,http://wiki.secondlife.com/wiki/LSL_Library" />
            </menu_item_call>
    </menu>
  </menu_bar>
    <layout_stack
        animate="false"
        clip="false"
        follows="left|top|right"
        name="script_editor_button_bar"
        layout="topleft"
        orientation="vertical"
        top_pad="0"
        width="497"
        left="0"
        height="20">
        <layout_panel
         auto_resize="false"
         follows="left|top"
         name="script_editor_buttons_panel"
         layout="topleft"
         width="497"
         height="20">
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Save"
             image_selected="Script_Save"
             image_pressed="Script_Save"
             tool_tip="Salvar script"
             label=""
             layout="topleft"
             name="save_btn"
             left="7"
             top="2"
             width="18" />
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Editor"
             image_selected="Script_Editor"
             image_pressed="Script_Editor"
             tool_tip="Editor externo de scripts"
             label=""
             layout="topleft"
             name="Edit_btn"
             left_pad="3"
             width="18" />
            
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Disk_Load"
             image_selected="Script_Disk_Load"
             image_pressed="Script_Disk_Load"
             tool_tip="Carregar script do disco"
             label=""
             layout="topleft"
             name="load_disk_btn"
             left_pad="14"
             width="18" />
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Disk_Save"
             image_selected="Script_Disk_Save"
             image_pressed="Script_Disk_Save"
             tool_tip="Salvar script no disco"
             label=""
             layout="topleft"
             name="save_disk_btn"
             left_pad="3"
             width="18" />
            
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Cut"
             image_selected="Script_Cut"
             image_pressed="Script_Cut"
             tool_tip="Recortar"
             label=""
             layout="topleft"
             name="cut_btn"
             left_pad="14"
             width="18" />
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Copy"
             image_selected="Script_Copy"
             image_pressed="Script_Copy"
             tool_tip="Copiar"
             label=""
             layout="topleft"
             name="copy_btn"
             left_pad="3"
             width="18" />
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Paste"
             image_selected="Script_Paste"
             image_pressed="Script_Paste"
             tool_tip="Colar"
             label=""
             layout="topleft"
             name="paste_btn"
             left_pad="3"
             width="18" />
            
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Undo"
             image_selected="Script_Undo"
             image_pressed="Script_Undo"
             tool_tip="Desfazer"
             label=""
             layout="topleft"
             name="undo_btn"
             left_pad="14"
             width="18" />
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Redo"
             image_selected="Script_Redo"
             image_pressed="Script_Redo"
             tool_tip="Refazer"
             label=""
             layout="topleft"
             name="redo_btn"
             left_pad="3"
             width="18" />
            
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Search"
             image_selected="Script_Search"
             image_pressed="Script_Search"
             tool_tip="Localizar/Substituir"
             label=""
             layout="topleft"
             name="search_btn"
             left_pad="14"
             width="18" />
            <button
             follows="left|top"
             height="18"
             image_unselected="Script_Config"
             image_selected="Script_Config"
             image_pressed="Script_Config"
             tool_tip="Preferências do editor de scripts"
             label=""
             layout="topleft"
             name="prefs_btn"
             left_pad="14"
             width="18" />
            
            <loading_indicator
             top="2"
             right="-10"
             height="18"
             width="18"
             layout="topleft"
             follows="top|right"
             name="progress_indicator"
             visible="false" />
            <icon
             top="2"
             right="-10"
             height="18"
             width="18"
             layout="topleft"
             follows="top|right"
             name="status_indicator"
             image_name="Script_NotRunning"
             visible="true" />
        </layout_panel>
    </layout_stack>
    <tab_container
     follows="all"
     halign="left"
     height="378"
     left="0"
	 top_pad="2"
     name="Tabset"
     tab_position="bottom"
     tab_width="100"
     tab_padding_right="0"
	 tab_height="16"
     width="487">
	<panel
	 bevel_style="none"
	 border_style="line"
	 follows="left|top|right|bottom"
	 height="377"
	 layout="topleft"
	 left="0"
	 top="0"
	 name="Script"
	 label="Script"
	 width="487">
		<script_editor
		 left="0"
		 top="0"
		 type="string"
		 length="1"
		 follows="left|top|right|bottom"
		 font="Scripting"
		 height="376"
		 ignore_tab="false"
		 layout="topleft"
		 max_length="262144"
		 name="Script Editor"
		 text_color="ScriptText"
		 default_color="ScriptText"
		 bg_writeable_color="ScriptBackground"
		 bg_focus_color="ScriptBackground"
		 text_readonly_color="ScriptText"
		 bg_readonly_color="ScriptBackground"
		 cursor_color="ScriptCursorColor"
		 width="487"
		 enable_tooltip_paste="true"
		 word_wrap="true"
		 show_context_menu="true">
			Carregando...
		</script_editor>
	</panel>
	<panel
	 bevel_style="none"
	 border_style="line"
	 follows="left|top|right|bottom"
	 height="377"
	 layout="topleft"
	 left="0"
	 name="Preprocessed"
	 label="Pré-processado"
	 width="487">
		<fs_lsl_preproc_viewer
		 left="0"
		 top="0"
		 type="string"
		 length="1"
		 follows="left|top|right|bottom"
		 font="Scripting"
		 height="376"
		 ignore_tab="false"
		 layout="topleft"
		 max_length="262144"
		 name="Post Editor"
		 text_color="ScriptText"
		 default_color="ScriptText"
		 bg_writeable_color="ScriptBackground"
		 bg_focus_color="ScriptBackground"
		 text_readonly_color="ScriptText"
		 bg_readonly_color="ScriptBackground"
		 bg_selected_color="ScriptSelectedColor"
		 cursor_color="ScriptCursorColor"
		 width="487"
		 word_wrap="true"
		 show_context_menu="true">
			Carregando...
		</fs_lsl_preproc_viewer>
	</panel>
	</tab_container>
    <scroll_list
    top_pad="10"
    left="0"
    follows="left|right|bottom"
    height="60"
    layout="topleft"
    name="lsl errors"
     width="487" />
  <combo_box
    follows="left|bottom"
    height="23"
    label="Inserir..."
    layout="topleft"
    name="Insert..."
     width="128" />
    <text
     follows="left|bottom"
    height="23"
    layout="topleft"
     left_pad="8"
     top_delta="4"
     name="line_col"
     value="Linha 0, coluna 0"
     width="128" />
  <button
    enabled="false"
    follows="right|bottom"
    height="23"
    label="Editar..."
    layout="topleft"
     top_delta="-4"
     right="-104"
     name="edit_btn_2"
     width="90" />
    <button
     follows="right|bottom"
     height="23"
     label="Salvar"
     label_selected="Salvar"
     layout="topleft"
     left_pad="4"
     name="save_btn_2"
     width="90" />
</panel>
