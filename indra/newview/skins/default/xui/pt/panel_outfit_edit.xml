<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<!-- Side tray Outfit Edit panel -->
<panel label="Editar outfit" name="outfit_edit">
	<string name="No Outfit" value="Sem outfit"/>
	<string name="unsaved_changes" value="Alterações não salvas"/>
	<string name="now_editing" value="Editando"/>
	<panel.string name="not_available">
		n/d
	</panel.string>
	<panel.string name="unknown">
		(desconhecido)
	</panel.string>
	<string name="Filter.All" value="Todos"/>
	<string name="Filter.Clothes/Body" value="Roupas/Corpo"/>
	<string name="Filter.Objects" value="Objetos"/>
	<string name="Filter.Clothing" value="Vestuário"/>
	<string name="Filter.Bodyparts" value="Partes do corpo"/>
	<string name="replace_body_part" value="Clique para substituir sua forma atual"/>
	<text name="title" value="Editar outfit"/>
	<panel label="bottom_panel" name="header_panel">
		<panel label="bottom_panel" name="outfit_name_and_status">
			<text name="status" value="Editando..."/>
			<text name="curr_outfit_name" value="[Outfit atual]"/>
		</panel>
	</panel>
	<layout_stack name="im_panels">
		<layout_panel label="Painel de controle de IM" name="outfit_wearables_panel">
			<layout_stack name="filter_panels">
				<layout_panel name="add_button_and_combobox">
					<button label="Adicionar mais" name="show_add_wearables_btn" tool_tip="Abrir/fechar"/>
				</layout_panel>
				<layout_panel name="filter_panel">
					<filter_editor label="Filtrar itens vestíveis do inventário" name="look_item_filter"/>
				</layout_panel>
			</layout_stack>
		</layout_panel>
		<layout_panel name="add_wearables_panel">
			<button label="Vestir item" name="plus_btn"/>
		</layout_panel>
	</layout_stack>
	<panel name="no_add_wearables_button_bar">
		<text name="avatar_complexity_label">
			Complexidade: [WEIGHT]
		</text>
		<button name="shop_btn_1" tool_tip="Visite o marketplace. Você também pode selecionar uma parte do seu outfit e clicar aqui para ver itens semelhantes."/>
	</panel>
	<panel name="add_wearables_button_bar">
		<text name="avatar_complexity_adding_label">
			Complexidade: [WEIGHT]
		</text>
		<button name="shop_btn_2" tool_tip="Visite o marketplace. Você também pode selecionar uma parte do seu outfit e clicar aqui para ver itens semelhantes."/>
	</panel>
	<panel name="save_revert_button_bar">
		<layout_stack name="button_bar_ls">
			<layout_panel name="save_btn_lp">
				<button label="Salvar" name="save_btn" />
			</layout_panel>
			<layout_panel name="save_as_btn_lp">
				<button label="Salvar como" name="save_as_btn" />
			</layout_panel>
			<layout_panel name="revert_btn_lp">
				<button label="Reverter alterações" name="revert_btn" tool_tip="Voltar para a última versão salva"/>
			</layout_panel>
		</layout_stack>
	</panel>
</panel>
