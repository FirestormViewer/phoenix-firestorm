	<text name="Give item:" value="Dar item:"/>
	<text name="Give inventory" tool_tip="Solte itens de inventário aqui para dar a esta pessoa.">
		Solte item de inventário aqui.
	</text>
	<layout_stack name="buttonstack">
		<layout_panel name="left_buttonstack">
			<button label="Mostrar no mapa" label_selected="Mostrar no mapa" name="show_on_map_btn" tool_tip="Localizar residente no mapa"/>
			<button label="Pagar" label_selected="Pagar" name="pay" tool_tip="Pagar dinheiro ao residente"/>
		</layout_panel>
		<layout_panel name="middle_buttonstack">
			<button label="Oferecer teleporte" label_selected="Oferecer teleporte" name="teleport" tool_tip="Oferecer um teleporte ao residente"/>
			<button label="Mensagem instantânea" label_selected="Mensagem instantânea" name="im" tool_tip="Abrir sessão de mensagem instantânea"/>
		</layout_panel>
		<layout_panel name="right_buttonstack">
			<button label="Adicionar amigo" label_selected="Adicionar amigo" name="add_friend" tool_tip="Oferecer amizade ao residente"/>
			<button label="Remover amigo" label_selected="Remover amigo" name="remove_friend" tool_tip="Encerrar amizade com este residente"/>
			<button label="Bloquear" name="block" tool_tip="Bloquear este residente"/>
			<button label="Desbloquear" name="unblock" tool_tip="Deixar de bloquear este residente"/>
		</layout_panel>
	</layout_stack>
	<check_box label="Mostrar na busca" tool_tip="Permite que outros residentes encontrem você nos resultados de busca" name="show_in_search"/>
	<check_box label="Mostrar data de nascimento completa" tool_tip="Permite que outros residentes vejam sua data de nascimento exata" name="hide_sl_age"/>
	<button name="save_description_changes" label="Salvar"/>
	<button name="discard_description_changes" label="Descartar"/>
