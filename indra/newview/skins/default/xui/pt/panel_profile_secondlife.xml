	<text_editor name="user_key" value="(carregando...)"/>
	<layout_stack name="imagepositioner">
		<layout_panel name="image_action_panel">
			<menu_button name="image_action_btn" tool_tip="Executar ações na foto do perfil"/>
		</layout_panel>
		<layout_panel name="label_stack">
			<text name="label" value="Data de nascimento:"/>
			<text_editor name="user_age" value="(carregando...)"/>
			<text name="label2" value="Conta:"/>
			<text name="partner_label" value="Parceiro:"/>
		</layout_panel>
	</layout_stack>
