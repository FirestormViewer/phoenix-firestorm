<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="land holdings floater" title="Terreno">
	<scroll_list name="parcel list">
		<column label="Parcela" name="name"/>
		<column label="Região" name="location"/>
		<column label="Tipo" name="type"/>
		<column label="Área" name="area"/>
		<column label="" name="hidden"/>
	</scroll_list>
	<button label="Teleportar" label_selected="Teleportar" name="Teleport" tool_tip="Teleportar para o centro deste terreno."/>
	<button label="Mapa" label_selected="Mapa" name="Show on Map" tool_tip="Mostrar este terreno no mapa-mundi."/>
	<text name="contrib_label">
		Contribuições para seus grupos:
	</text>
	<scroll_list name="grant list">
		<column label="Grupo" name="group"/>
		<column label="Área" name="area"/>
	</scroll_list>
	<text name="allowed_label">
		Terreno permitido no plano de pagamento atual:
	</text>
	<text name="allowed_text">
		[AREA] m².
	</text>
	<text name="current_label">
		Terreno atualmente possuído:
	</text>
	<text name="current_text">
		[AREA] m².
	</text>
	<text name="available_label">
		Disponível para compra de terrenos:
	</text>
	<text name="available_text">
		[AREA] m².
	</text>
	<string name="area_string">
		[AREA] m².
	</string>
</floater>
