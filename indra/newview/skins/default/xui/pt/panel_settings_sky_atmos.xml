<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel label="Atmosfera e iluminação" name="panel_settings_sky_atmos">
	<string name="hdr_string">
		Escala HDR:
	</string>
	<string name="brightness_string">
		Brilho:
	</string>
	<string name="hdr_tooltip">
		Intensidade dos efeitos de exposição, como céu radiante realista e exposição dinâmica. 1.0 é o padrão, 0 desativa, e valores entre 0 e 1 misturam ambiente com HDR.
	</string>
	<layout_stack name="main_ls">
		<layout_panel name="top_lp">
			<text name="ambient_color_label">
				Cor ambiente:
			</text>
			<text name="blue_horizon_label">
				Horizonte azul:
			</text>
			<text name="blue_density_label">
				Densidade azul:
			</text>
		</layout_panel>
		<layout_panel name="bottom_lp">
			<layout_stack name="atmosphere1">
				<layout_panel name="left_lp">
					<text name="haze_horizon_label">
						Névoa no horizonte:
					</text>
					<text name="haze_density_label">
						Densidade da névoa:
					</text>
					<text name="moisture_level_label">
						Nível de umidade:
					</text>
					<text name="droplet_radius_label">
						Raio da gotícula:
					</text>
					<text name="ice_level_label">
						Nível de gelo:
					</text>
				</layout_panel>
				<layout_panel name="right_lp">
					<text name="density_multiplier_label" width="120">
						Multiplicador de densidade:
					</text>
					<slider name="density_multip" width="199"/>
					<text name="distance_multiplier_label" width="120">
						Multiplicador de distância:
					</text>
					<slider name="distance_multip" width="199"/>
					<text name="maximum_altitude_label" width="120">
						Altitude máxima:
					</text>
					<slider name="max_alt" width="199"/>
					<text name="probe_ambiance_label" tool_tip="Intensidade de radiância. Ativa o modelo de iluminação HDR quando não for 0." width="120">
						Ambiência da sonda de reflexão (HDR):
					</text>
					<slider name="probe_ambiance" tool_tip="Intensidade da iluminação indireta baseada no ambiente. Com HDR em 0, a escala vira brilho." width="187"/>
					<text name="scene_gamma_label" width="120">
						Brilho:
					</text>
					<slider name="scene_gamma" width="187"/>
				</layout_panel>
			</layout_stack>
		</layout_panel>
	</layout_stack>
</panel>
