<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="area_search" title="Busca de área">
	<tab_container name="area_searchtab">
		<panel name="area_search_list_panel" label="Lista">
			<panel.string name="ListedPendingTotalBlank">
				Listados | Pendentes | Total
			</panel.string>
			<panel.string name="ListedPendingTotalFilled">
				[LISTED] Listados | [PENDING] Pendentes | [TOTAL] Total
			</panel.string>
			<fs_scroll_list name="result_list">
				<fs_scroll_list.columns name="distance" label="Dist." tool_tip="Distância do seu avatar até o objeto."/>
				<fs_scroll_list.columns name="name" label="Nome"/>
				<fs_scroll_list.columns name="description" label="Descrição" width="170"/>
				<fs_scroll_list.columns name="price" label="Preço" tool_tip="Preço do objeto, caso esteja à venda."/>
				<fs_scroll_list.columns name="land_impact" label="LI" tool_tip="Valor contado no limite máximo de prims do lote."/>
				<fs_scroll_list.columns name="prim_count" label="Prims" tool_tip="Quantidade de prims que compõem o objeto."/>
				<fs_scroll_list.columns name="owner" label="Proprietário"/>
				<fs_scroll_list.columns name="group" label="Grupo" tool_tip="Grupo ao qual o objeto está atribuído."/>
				<fs_scroll_list.columns name="creator" label="Criador" width="150"/>
				<fs_scroll_list.columns name="last_owner" label="Último proprietário" width="140" tool_tip="Quem foi o último proprietário do objeto."/>
			</fs_scroll_list>
			<button name="Refresh" label="Atualizar" width="100"/>
			<text name="counter" left_delta="110">
				Listados | Pendentes | Total
			</text>
			<check_box name="beacons" label="Mostrar beacons" left_pad="90" width="170"/>
		</panel>
		<panel label="Buscar" name="area_search_find_panel">
			<text name="name_label">
				Nome:
			</text>
			<text name="desc_label">
				Descrição:
			</text>
			<text name="owner_label">
				Proprietário:
			</text>
			<text name="group_label">
				Grupo:
			</text>
			<text name="creator_label">
				Criador:
			</text>
			<text name="last_owner_label">
				Último proprietário:
			</text>
			<check_box name="regular_expression" label="Usar expressão regular"/>
			<button name="search" label="Pesquisar"/>
			<button name="clear" label="Limpar"/>
		</panel>
		<panel label="Filtro" name="area_search_filter_panel">
			<text name="only_list">
				Listar somente objetos que sejam:
			</text>
			<check_box name="filter_locked" label="Bloqueado"/>
			<check_box name="filter_physical" label="Físico"/>
			<check_box name="filter_phantom" label="Fantasma"/>
			<check_box name="filter_temporary" label="Temporário"/>
			<check_box name="filter_attachment" label="Anexo"/>
			<check_box name="filter_moap" label="Mídia compartilhada"/>
			<check_box name="filter_perm_copy" label="Copiar"/>
			<check_box name="filter_perm_modify" label="Modificar"/>
			<check_box name="filter_perm_transfer" label="Transferir"/>
			<check_box name="filter_reflection_probe" label="Sondas de reflexão" tool_tip="Inclui apenas sondas manuais, não automáticas. Inclui sondas de espelho apenas se espelhos estiverem ativados nas preferências gráficas. Se a cobertura de reflexão estiver em 'nenhuma' ou a sonda não estiver bakeada, objetos podem não ser identificados."/>
			<check_box name="filter_for_sale" label="À venda entre" width="150"/>
			<text name="and">
				e
			</text>
			<text name="mouse_text">
				Ação do clique do mouse
			</text>
			<combo_box name="click_action" tool_tip="Ação executada ao clicar no objeto.">
				<combo_box.item label=" " name="click_blank"/>
				<combo_box.item label="Qualquer" name="click_any"/>
				<combo_box.item label="Tocar" name="click_touch"/>
				<combo_box.item label="Sentar" name="click_sit"/>
				<combo_box.item label="Comprar" name="click_buy"/>
				<combo_box.item label="Pagar" name="click_pay"/>
				<combo_box.item label="Abrir" name="click_open"/>
				<combo_box.item label="Reproduzir" name="click_play"/>
				<combo_box.item label="Abrir mídia" name="click_open_media"/>
				<combo_box.item label="Zoom" name="click_zoom"/>
			</combo_box>
			<check_box name="filter_distance" label="Distância entre" width="140"/>
			<text name="and2">
				e
			</text>
			<check_box name="filter_agent_parcel_only" label="Somente lote atual" width="140"/>
			<text name="only_list">
				Excluir objetos que sejam:
			</text>
			<check_box name="exclude_attachment" label="Anexo"/>
			<check_box name="exclude_physical" label="Físico"/>
			<check_box name="exclude_temporary" label="Temporário"/>
			<check_box name="exclude_reflection_probes" label="Sondas de reflexão"/>
			<check_box name="exclude_childprim" label="Prim filho"/>
			<check_box name="exclude_neighbor_region" label="Regiões vizinhas"/>
			<button name="apply" label="Aplicar"/>
			<button name="save_as_default" label="Salvar como padrão"/>
		</panel>
		<panel label="Opções" name="area_search_options_panel">
			<text name="display_column">
				Exibir colunas:
			</text>
			<check_box name="show_distance" label="Distância"/>
			<check_box name="show_name" label="Nome"/>
			<check_box name="show_description" label="Descrição"/>
			<check_box name="show_price" label="Preço"/>
			<check_box name="show_land_impact" label="Impacto de terreno"/>
			<check_box name="show_prim_count" label="Qtd. de prims"/>
			<check_box name="show_owner" label="Proprietário"/>
			<check_box name="show_group" label="Grupo"/>
			<check_box name="show_creator" label="Criador"/>
			<check_box name="show_last_owner" label="Último proprietário"/>
		</panel>
		<panel label="Avançado" name="area_search_advanced_panel">
			<check_box name="double_click_touch" label="Duplo clique toca no objeto"/>
			<check_box name="double_click_buy" label="Duplo clique compra o objeto"/>
			<check_box name="double_click_sit" label="Duplo clique senta no objeto"/>
		</panel>
	</tab_container>
</floater>
