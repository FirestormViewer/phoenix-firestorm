<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel label="Terra e L$" name="land_money_tab">
	<panel.string name="help_text">
		Um aviso será exibido enquanto o valor total de terra usada for igual ou menor que a contribuição total.
	</panel.string>
	<panel.string name="cant_view_group_land_text">
		Você não tem permissão para ver as propriedades de terra do grupo.
	</panel.string>
	<panel.string name="epmty_view_group_land_text">
		Sem entradas
	</panel.string>
	<panel.string name="cant_view_group_accounting_text">
		Você não tem permissão para ver as informações financeiras do grupo.
	</panel.string>
	<panel.string name="loading_txt">
		Carregando...
	</panel.string>
	<panel.string name="land_contrib_error">
		Não foi possível definir sua contribuição de terra.
	</panel.string>
	<scroll_list name="group_parcel_list">
		<scroll_list.columns label="Parcela" name="name"/>
		<scroll_list.columns label="Região" name="location"/>
		<scroll_list.columns label="Tipo" name="type"/>
		<scroll_list.columns label="Área" name="area"/>
		<scroll_list.columns label="Oculto" name="hidden"/>
	</scroll_list>
	<button label="Mapa" label_selected="Mapa" name="map_button"/>
	<text name="total_land_in_use_label" width="150">
		Total de terra em uso:
	</text>
	<text name="total_land_in_use_value">
		[AREA] m².
	</text>
	<text name="land_available_label" width="150">
		Terra disponível:
	</text>
	<text name="land_available_value">
		[AREA] m².
	</text>
	<text name="total_contributed_land_label" width="150">
		Contribuição total:
	</text>
	<text name="total_contributed_land_value">
		[AREA] m².
	</text>
	<text name="your_contribution_label" width="150">
		Sua contribuição:
	</text>
	<text name="your_contribution_units">
		m²
	</text>
	<text name="your_contribution_max_value">
		([AMOUNT] máx.)
	</text>
	<text name="group_money_heading" width="120">
		L$ do grupo
	</text>
	<icon image_name="Parcel_Exp_Color" left="100" name="group_over_limit_icon"/>
	<text name="group_over_limit_text">
		Você não tem terra suficiente.
	</text>


	<tab_container name="group_money_tab_container">
		<panel label="Planejamento" name="group_money_planning_tab">
			<text_editor name="group_money_planning_text">
				Carregando...
			</text_editor>
		</panel>
		<panel label="Detalhes" name="group_money_details_tab">
			<text_editor name="group_money_details_text">
				Carregando...
			</text_editor>
			<button label="&lt; Anterior" label_selected="&lt; Anterior" name="earlier_details_button" tool_tip="Voltar"/>
			<button label="Próximo &gt;" label_selected="Próximo &gt;" name="later_details_button" tool_tip="Avançar"/>
		</panel>
		<panel label="Vendas" name="group_money_sales_tab">
			<text_editor name="group_money_sales_text">
				Carregando...
			</text_editor>
			<button label="&lt; Anterior" label_selected="&lt; Anterior" name="earlier_sales_button" tool_tip="Voltar"/>
			<button label="Próximo &gt;" label_selected="Próximo &gt;" name="later_sales_button" tool_tip="Avançar"/>
		</panel>
	</tab_container>
</panel>
