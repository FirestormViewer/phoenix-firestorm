<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="avatarrendersettings" title="Exceções de exibição de Avatar">
	<floater.string name="av_render_never">
		Nunca
	</floater.string>
	<floater.string name="av_render_always">
		Sempre
	</floater.string>
	<filter_editor label="Filtrar Avatares" name="filter_input"/>
	<menu_button name="plus_btn" tool_tip="Adicionar pessoa à lista"/>
