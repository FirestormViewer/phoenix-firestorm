<panel label="Vendas de terreno" name="panel_dir_land">
    <string name="searching_text">
        Buscando...
    </string>
    <string name="not_found_text">
        Nada encontrado.
    </string>
    <string name="found_text">
        [COUNT] encontrado(s).
    </string>
    <text name="find">
        Digite os termos de busca:
    </text>
    <combo_box name="type">
        <combo_item name="AllTypes" label="Todos os tipos"/>
        <combo_item name="Auction" label="Leilões"/>
        <combo_item name="MainlandSales" label="Venda no continente"/>
        <combo_item name="EstateSales" label="Venda em região estate"/>
    </combo_box>
    <icon tool_tip="Geral" name="rating_icon_general"/>
    <icon tool_tip="Moderado" name="rating_icon_moderate"/>
    <icon tool_tip="Adulto" name="rating_icon_adult"/>
    <check_box label="Preço &#8804; " name="pricecheck"/>
    <text name="pricecheck_symbol">
        L$
    </text>
    <check_box label="Área &#8805; " name="areacheck" width="65"/>
    <text name="areacheck_symbol">
        m²
    </text>
    <button label="Buscar" name="Search"/>
    <scroll_list name="results">
        <column label="Nome" name="name" />
        <column label="Tipo" name="landtype" />
        <column label="Preço L$" name="price"/>
        <column label="Área" name="area"/>
        <column label="L$/m²" name="per_meter"/>
    </scroll_list>
    <button tool_tip="Página anterior" name="prev_btn"/>
    <button tool_tip="Próxima página" name="next_btn"/>
</panel>
