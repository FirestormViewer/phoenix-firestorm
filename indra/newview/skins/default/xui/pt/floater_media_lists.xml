<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<floater name="floatermedialists" title="Listas de mídia">
	<floater.string name="EnterUrlAllow">
		Digite o domínio ou URL para sempre permitir:
	</floater.string>
	<floater.string name="EnterUrlDeny">
		Digite o domínio ou URL para nunca permitir:
	</floater.string>
	<layout_stack name="lists_layout_stack">
		<layout_panel name="whitelist_layout_panel">
			<text name="whitelist_text">
				Domínios permitidos:
			</text>
			<layout_stack name="whitelist_buttons_layout_stack">
				<layout_panel name="whitelist_buttons_panel_add">
					<button label="Adicionar..." label_selected="Adicionar..." name="add_whitelist"/>
				</layout_panel>
				<layout_panel name="whitelist_buttons_panel_remove">
					<button label="Remover" label_selected="Remover" name="remove_whitelist"/>
				</layout_panel>
			</layout_stack>
		</layout_panel>

		<layout_panel name="blacklist_layout_panel">
			<text name="blacklist_text">
				Domínios bloqueados:
			</text>
			<layout_stack name="blacklist_buttons_layout_stack">
				<layout_panel name="blacklist_buttons_panel_add">
					<button label="Adicionar..." label_selected="Adicionar..." name="add_blacklist"/>
				</layout_panel>
				<layout_panel name="blacklist_buttons_panel_remove">
					<button label="Remover" label_selected="Remover" name="remove_blacklist"/>
				</layout_panel>
			</layout_stack>
		</layout_panel>
	</layout_stack>
</floater>
