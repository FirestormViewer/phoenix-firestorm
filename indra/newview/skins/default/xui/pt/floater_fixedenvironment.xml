<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="Fixed Environment" title="Ambiente fixo">
	<string name="edit_sky">
		Editar céu:
	</string>
	<string name="edit_water">
		Editar água:
	</string>
	<layout_stack name="floater_stack">
		<layout_panel name="info_panel">
			<text name="info_panel_label">
				Nome:
			</text>
			<button label="Carregar" name="btn_load" tool_tip="Carregar configurações do inventário"/>
			<button label="Importar" name="btn_import" tool_tip="Importar configurações legadas do disco."/>
		</layout_panel>
		<layout_panel name="tab_area">
			<tab_container name="tab_settings" tab_width="165"/>
		</layout_panel>
		<layout_panel name="button_panel">
			<layout_stack name="button_bar_ls">
				<layout_panel name="save_btn_lp">
					<button label="Salvar" name="btn_commit"/>
				</layout_panel>
				<layout_panel name="revert_btn_lp">
					<button label="Cancelar" name="btn_cancel" tool_tip="Reverter para a última versão salva"/>
				</layout_panel>
			</layout_stack>
		</layout_panel>
	</layout_stack>
</floater>
