<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater name="worldmap" title="Mapa">
	<floater.string name="UnnamedParcel">
		(Parcela sem nome)
	</floater.string>
	<layout_stack name="resizing_stack">
		<layout_panel name="map_details_panel">
			<panel name="layout_panel_1">
				<text name="events_label">
					Legenda
				</text>
			</panel>
			<panel name="layout_panel_2">
				<button label="Minha posição" label_selected="Onde estou?" name="Show My Location" tool_tip="Centralizar o mapa na posição do meu avatar"/>
				<text name="me_label">
					Posição atual
				</text>
				<check_box label="Residentes" name="people_chk"/>
				<text name="person_label">
					Pessoa
				</text>
				<check_box label="Infohub" name="infohub_chk"/>
				<text name="infohub_label">
					Infohub
				</text>
				<check_box label="Terreno à venda" name="land_for_sale_chk"/>
				<text name="land_sale_label">
					Venda de terra
				</text>
				<text name="auction_label">
					Leilão de terra
				</text>
				<text name="by_owner_label">
					pelo proprietário
				</text>
				<button label="Ir para casa" label_selected="Ir para casa" name="Go Home" tool_tip="Teleportar para casa"/>
				<text name="Home_label">
					Casa
				</text>
				<text name="events_label">
					Eventos:
				</text>
				<check_box label="PG" name="event_chk"/>
				<text name="pg_label">
					Geral
				</text>
				<check_box initial_value="true" label="Mature" name="events_mature_chk"/>
				<text name="events_mature_label">
					Moderado
				</text>
				<check_box label="Adult" name="events_adult_chk"/>
				<text name="events_adult_label">
					Adulto
				</text>
			</panel>
			<panel name="layout_panel_3">
				<text name="find_on_map_label">
					Mostrar no mapa
				</text>
			</panel>
			<panel name="layout_panel_4">
				<combo_box label="Amigos online" name="friend combo" tool_tip="Mostrar amigos no mapa">
					<combo_box.item label="Meus amigos: online" name="item1"/>
				</combo_box>
				<combo_box label="Minhas marcas" name="landmark combo" tool_tip="Marca a exibir no mapa">
					<combo_box.item label="Minhas marcas" name="item1"/>
				</combo_box>
				<search_editor label="Regiões por nome" name="location" tool_tip="Digite o nome de uma região"/>
				<button label="Buscar" name="DoSearch" tool_tip="Buscar uma região"/>
				<scroll_list name="search_results">
					<scroll_list.columns label="" name="icon"/>
					<scroll_list.columns label="" name="sim_name"/>
				</scroll_list>
			</panel>
			<panel name="layout_panel_7">
				<text name="events_label">
					Local:
				</text>
				<button label="Teleportar" label_selected="Teleportar" name="Teleport" tool_tip="Teleportar para a posição selecionada"/>
				<button label="Copiar SLurl" name="copy_slurl" tool_tip="Copia a posição atual como SLurl para usar na web." width="88"/>
				<button label="Limpar" name="Clear" tool_tip="Desativar rastreamento e redefinir o mapa." width="75"/>
				<button label="Mostrar destino" label_selected="Mostrar destino" name="Show Destination" tool_tip="Centralizar o mapa na posição selecionada"/>
				<button label="Rastrear região" name="track_region" tool_tip="Adicionar região ao rastreador de regiões"/>
			</panel>
		</layout_panel> 
	</layout_stack> 
</floater>
