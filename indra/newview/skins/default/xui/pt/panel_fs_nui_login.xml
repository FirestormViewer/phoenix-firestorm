<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel name="panel_login">
	<panel.string name="forgot_password_url">
		http://secondlife.com/account/request.php?lang=pt
	</panel.string>
	<string name="ServerComboTooltip">
		Uma grade conhecida ou uma URI de grade
	</string>
	<layout_stack name="ui_stack">
		<layout_panel name="ui_container">
			<layout_stack name="vert_stack_left">
				<layout_panel name="1st_row">
					<layout_stack name="1st_row_stack">
						<layout_panel name="login">
							<combo_box name="username_combo" label="Nome de usuário" tool_tip="Nome de usuário escolhido no cadastro, como &quot;berndschmidt12&quot; ou &quot;Love Sun&quot;"/>
							<check_box label="Salvar nome de usuário" name="remember_username_check"/>
						</layout_panel>
						<layout_panel name="delete_container">
							<button tool_tip="Excluir este nome de usuário" name="remove_user_btn"/>
						</layout_panel>
						<layout_panel name="password_container">
							<line_editor name="password_edit" label="Senha"/>
							<check_box label="Salvar senha" name="remember_check"/>
							<button name="password_show_btn" tool_tip="Mostrar senha"/>
							<button name="password_hide_btn" tool_tip="Ocultar senha"/>
						</layout_panel>
						<layout_panel name="start_location_panel">
							<combo_box name="start_location_combo" label="Iniciar em:">
								<combo_box.item label="Última localização" name="MyLastLocation"/>
								<combo_box.item label="Casa" name="MyHome"/>
								<combo_box.item label="&lt;digite uma região&gt;" name="Typeregionname"/>
							</combo_box>
						</layout_panel>
					</layout_stack>
				</layout_panel>
				<layout_panel name="2nd_row">
					<layout_stack name="2nd_row_stack">
						<layout_panel name="grid_panel">
							<text name="grid_login_text">
								Grade:
							</text>
							<text name="grid_builder_text">
								+ Clique para adicionar grades
							</text>
						</layout_panel>
						<layout_panel name="mode_selection">
							<text name="mode_selection_text">
								Modo:
							</text>
							<combo_box name="mode_combo" tool_tip="Escolha o estilo de viewer que você conhece melhor para ajustar os padrões às suas necessidades.">
								<combo_box.item label="Hybrid" name="Hybrid"/>
								<combo_box.item label="Texto" name="Text"/>
							</combo_box>
						</layout_panel>
					</layout_stack>
				</layout_panel>
			</layout_stack>
			<button label="Entrar" name="connect_btn"/>
			<text name="create_new_account_text">
				Criar conta
			</text>
			<text name="forgot_password_text">
				Esqueceu a senha?
			</text>
		</layout_panel>
	</layout_stack>
</panel>
