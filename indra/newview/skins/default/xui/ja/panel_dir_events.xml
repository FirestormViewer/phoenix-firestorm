<panel label="イベント" name="panel_dir_events">
	<string name="searching_text">
		検索しています…
	</string>
	<string name="not_found_text">
		見つかりませんでした。
	</string>
	<string name="found_text">
		[COUNT]件見つかりました。
	</string>
	<text name="find">
		検索語句を入力：
	</text>
	<combo_box name="category_combo">
		<combo_item label="全カテゴリ" name="any"/>
		<combo_item label="討論" name="discussion"/>
		<combo_item label="スポーツ" name="sports"/>
		<combo_item label="ライブＤＪ" name="dj"/>
		<combo_item label="ライブミュージック" name="music"/>
		<combo_item label="商用" name="commercial"/>
		<combo_item label="夜の生活／エンターティメント" name="nightlife"/>
		<combo_item label="ゲーム／コンテンスト" name="games"/>
		<combo_item label="野外劇" name="pageants"/>
		<combo_item label="教育" name="education"/>
		<combo_item label="芸術と文化" name="arts"/>
		<combo_item label="チャリティー／サポートグループ" name="charity"/>
		<combo_item label="その他" name="misc"/>
	</combo_box>
	<scroll_list name="results">
		<column label="名前" name="name" />
		<column label="時間（ＰＴ）" name="date" />
		<column label="時間" name="time" />
	</scroll_list>
	<button tool_tip="前のページに戻ります。" name="prev_btn"/>
	<button tool_tip="次のページに進みます。" name="next_btn"/>
	<radio_group name="date_mode">
		<radio_item name="current" label="進行中及び今後のイベント"/>
		<radio_item name="date" label="日付"/>
	</radio_group>
	<button label="«" label_selected="«" name="back_btn" tool_tip="１日戻る"/>
	<button label="»" label_selected="»" name="forward_btn" tool_tip="１日進める" />
</panel>
