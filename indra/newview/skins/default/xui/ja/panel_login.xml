<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel name="panel_login">
	<panel.string name="forgot_password_url">https://accounts.secondlife.com/forgot_password/?lang=ja-JP</panel.string>
	<layout_stack name="main_stack">
		<layout_panel name="center_stage">
			<layout_stack name="ui_stack">
				<layout_panel name="ui_container">
					<combo_box label="ユーザ名" tool_tip="bobsmith12やSteller Sunshineのような、登録したときのユーザ名を選んでください。" name="username_combo"/>
					<check_box label="ユーザ名を記録" name="remember_name" tool_tip="既に記憶されているユーザ名は、私＞初期設定＞詳細設定＞記憶されているユーザ名から削除できます。"/>
					<line_editor name="password_edit" label="パスワード"/>
					<check_box label="パスワードを記録" name="remember_password"/>
					<text name="location_text">
						開始位置
					</text>
					<combo_box label="お気に入りの場所" name="start_location_combo">
						<combo_box.item label="最後にいた場所" name="MyLastLocation"/>
						<combo_box.item label="ホーム" name="MyHome"/>
					</combo_box>
					<layout_stack name="login_stack">
						<layout_panel name="grid_panel">
							<text name="grid_text">
								グリッド
							</text>
							<combo_box label="グリッドを選択" name="server_combo"/>
						</layout_panel>
						<layout_panel name="login_panel">
							<button label="ログイン" name="connect_btn"/>
							<text name="forgot_password_text">
								パスワードを忘れましたか？
							</text>
							<button label="アカウント作成" name="sign_btn"/>
						</layout_panel>
					</layout_stack>
				</layout_panel>
			</layout_stack>
		</layout_panel>
	</layout_stack>
</panel>
