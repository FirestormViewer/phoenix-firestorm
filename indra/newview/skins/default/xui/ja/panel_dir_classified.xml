<panel label="クラシファイド広告" name="panel_dir_classified">
	<string name="searching_text">
		検索しています…
	</string>
	<string name="not_found_text">
		見つかりませんでした。
	</string>
	<string name="found_text">
		[COUNT]件見つかりました。
	</string>
	<text name="find">
		検索語を入力：
	</text>
	<combo_box name="Category">
		<combo_item name="AnyCategory" label="全カテゴリ"/>
		<combo_item name="Shopping" label="ショッピング"/>
		<combo_item name="LandRental" label="土地のレンタル"/>
		<combo_item name="PropertyRental" label="物件のレンタル"/>
		<combo_item name="SpecialAttraction" label="特別なアトラクション"/>
		<combo_item name="NewProducts" label="新製品"/>
		<combo_item name="Employment" label="雇用"/>
		<combo_item name="Wanted" label="募集"/>
		<combo_item name="Service" label="サービス"/>
		<combo_item name="Personal" label="個人"/>
	</combo_box>
	<scroll_list name="results">
		<column label="名前" name="name"/>
		<column label="価格" name="price"/>
	</scroll_list>
	<button tool_tip="前のページ" name="prev_btn"/>
	<button tool_tip="次のページ" name="next_btn"/>
</panel>
